---
/**
 * MegaMenuCategory.astro — Molecule
 * BeautyHome / KORA · NODO Studio
 *
 * Elemento de navegación rico (Mega Menu) para el Navbar Desktop.
 * Muestra las categorías principales con imagen representativa y links útiles.
 */

interface CollectionItem {
  id: string;
  name: string;
  href: string;
  image: string;
}

interface Props {
  title: string;
  collections: CollectionItem[];
  viewAllHref: string;
  class?: string;
}

const { title, collections, viewAllHref, class: extraClass = '' } = Astro.props;
---

<div class:list={["absolute top-full left-0 w-full bg-white border-b border-sand-200 shadow-sm opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50", extraClass]}>
  <div class="max-w-[1320px] mx-auto px-8 py-10 flex gap-12">
    
    {/* Info Block */}
    <div class="w-[280px] shrink-0 border-r border-sand-200 pr-8">
      <h3 class="font-display text-3xl font-light text-petrol mb-4">{title}</h3>
      <p class="font-sans text-[14px] text-sand-900/60 leading-relaxed mb-6">
        Curaduría local y funcional para el confort de tu perro.
      </p>
      <a href={viewAllHref} class="inline-flex items-center gap-2 font-sans text-[12px] font-semibold tracking-[0.05em] uppercase text-watermelon hover:text-watermelon-hover transition-colors">
        Ver todo el catálogo
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
      </a>
    </div>

    {/* Collections Display */}
    <div class="flex-1 grid grid-cols-4 gap-6">
      {collections.map((coll) => (
        <a href={coll.href} class="group/item relative rounded-f2-md overflow-hidden bg-sand-100 block">
          <div class="relative aspect-4/3 rounded-f2-md overflow-hidden bg-sand-100 group/img">
            <img src={coll.image} alt={coll.name} class="w-full h-full object-cover f2-transition group-hover/img:scale-105" />
            <div class="absolute inset-0 bg-linear-to-t from-black/20 to-transparent"></div>
          </div>
          <span class="absolute bottom-4 left-4 font-sans text-[14px] font-medium text-white tracking-[0.02em]">
            {coll.name}
          </span>
        </a>
      ))}
    </div>
    
  </div>
</div>
