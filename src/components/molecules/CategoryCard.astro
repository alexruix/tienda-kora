---
/**
 * CategoryCard Molecule — Tarjeta de categoría con imagen + gradiente + label + count
 * BeautyHome · NODO Studio
 *
 * Uso:
 *   <CategoryCard id="living" name="Living" label="Space" href="/category/living" count={6} />
 */

interface Props {
  id:      string;
  name:    string;
  label:   string;
  href:    string;
  count:   number;
  image?:  string;
  class?:  string;
}

const {
  id,
  name,
  label,
  href,
  count,
  image,
  class: extraClass = "",
} = Astro.props;
---

<a
  href={href}
  class:list={[
    "group relative aspect-[3/4] rounded-f2-lg overflow-hidden cursor-pointer bg-sand-200 block no-underline shadow-f2-rest hover:shadow-f2-hover f2-transition",
    extraClass,
  ]}
  aria-label={`Shop ${name} — ${count} piece${count !== 1 ? "s" : ""} available`}
>
  {/* Background — imagen real o placeholder de color */}
  {image ? (
    <img
      src={image}
      alt=""
      aria-hidden="true"
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover transition-transform duration-[800ms] ease-fluent group-hover:scale-105"
    />
  ) : (
    <div
      class="absolute inset-0 bg-sand-300 transition-transform duration-[800ms] ease-fluent group-hover:scale-105"
      aria-hidden="true"
    />
  )}

  {/* Gradient overlay */}
  <div
    class="absolute inset-0 bg-gradient-to-t from-petrol/90 via-petrol/20 to-transparent"
    aria-hidden="true"
  />

  {/* Arrow icon */}
  <div
    class="absolute top-5 right-5 w-10 h-10 rounded-full fluent-acrylic flex items-center justify-center z-10 f2-transition group-hover:rotate-45"
    aria-hidden="true"
  >
    <svg
      width="16"
      height="16"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      class="text-petrol"
      stroke-width="2"
    >
      <line x1="5" y1="12" x2="19" y2="12" />
      <polyline points="12 5 19 12 12 19" />
    </svg>
  </div>

  {/* Text content */}
  <div class="absolute bottom-0 left-0 right-0 p-6 z-10 font-sans">
    <p class="text-[11px] tracking-[0.2em] uppercase text-white/60 mb-2">
      {label}
    </p>
    <p class="font-display text-4xl font-light text-white leading-[1.1]">
      {name}
    </p>
    <p class="text-[13px] text-white/60 mt-2">
      {count} {count === 1 ? "piece" : "pieces"} available
    </p>
  </div>
</a>
