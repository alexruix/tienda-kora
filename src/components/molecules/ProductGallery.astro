---
/**
 * ProductGallery.astro — Molecule
 * BeautyHome / KORA · NODO Studio
 *
 * Muestra la imagen principal y miniaturas en la vista de producto.
 * Como es Astro puro, usamos enlaces ancla `#main-img` para
 * cambiar la imagen visible sin Javascript pesado.
 */

interface ImageItem {
  src: string;
  alt: string;
  id: string;
}

interface Props {
  images: ImageItem[];
  class?: string;
}

const { images, class: extraClass = '' } = Astro.props;
---

<div class:list={["flex flex-col-reverse md:flex-row gap-4", extraClass]}>
  {/* Thumbnails */}
  <div class="flex flex-row md:flex-col gap-3 overflow-x-auto md:overflow-y-auto [scrollbar-width:none] [&::-webkit-scrollbar]:hidden w-full md:w-[80px] shrink-0">
    {images.map((img) => (
      <a 
        href={`#${img.id}`}
        class="block w-16 h-16 md:w-full md:h-20 shrink-0 rounded-f2-md overflow-hidden border border-transparent hover:border-petrol/50 focus:border-petrol focus:ring-2 focus:ring-offset-2 transition-all"
      >
        <img 
          src={img.src} 
          alt={`Thumbnail of ${img.alt}`} 
          class="w-full h-full object-cover" 
          loading="lazy"
        />
      </a>
    ))}
  </div>

  {/* Main Image Viewport */}
  <div class="relative w-full aspect-square bg-sand-100 rounded-f2-lg overflow-hidden group">
    {/* Contenedor que "scrollea" a la imagen activa */}
    <div class="flex w-full h-full overflow-hidden scroll-smooth snap-x snap-mandatory">
      {images.map((img) => (
        <div id={img.id} class="w-full h-full shrink-0 snap-center relative">
          <img 
            src={img.src} 
            alt={img.alt} 
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
            loading="lazy"
          />
        </div>
      ))}
    </div>
    
    {/* Hint para el zoom */}
    <div class="absolute bottom-4 right-4 bg-white/80 backdrop-blur-sm p-2 rounded-full text-petrol opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        <line x1="11" y1="8" x2="11" y2="14"></line>
        <line x1="8" y1="11" x2="14" y2="11"></line>
      </svg>
    </div>
  </div>
</div>
