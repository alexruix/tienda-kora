---
/**
 * SocialProof.astro — Molecule
 * BeautyHome / KORA · NODO Studio
 *
 * Muestra estrellas de rating y un pequeño testimonial. Ideal para 
 * ubicar cerca del botón de compra o en la galería de producto.
 */

interface Props {
  rating: number;
  reviewCount?: number;
  highlightText?: string;
  class?: string;
}

const { 
  rating, 
  reviewCount = 0, 
  highlightText,
  class: extraClass = '' 
} = Astro.props;

// Estrellas llenas (cálculo básico)
const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
---

<div class:list={["flex flex-col gap-1.5", extraClass]}>
  <div class="flex items-center gap-2">
    <div class="flex text-watermelon" aria-hidden="true">
      {Array.from({ length: fullStars }).map(() => (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
      ))}
      {hasHalfStar && (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" class="opacity-50">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
        </svg>
      )}
    </div>
    
    <span class="font-sans text-[12px] font-medium text-sand-900">
      {rating.toFixed(1)} <span class="text-sand-900/40 font-normal">({reviewCount})</span>
    </span>
  </div>
  
  {highlightText && (
    <p class="font-sans text-[13px] text-sand-900/70 italic leading-snug">
      "{highlightText}"
    </p>
  )}
</div>
