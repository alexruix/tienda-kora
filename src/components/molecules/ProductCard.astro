---
/**
 * ProductCard Molecule
 * KORA · NODO Studio
 *
 * Mobile UX improvements:
 * - Wishlist & Add-to-cart buttons always visible on mobile (no hover required)
 * - Wider tap targets
 * - Uses [@media(hover:none)] to differentiate touch from pointer devices
 */
import PriceDisplay from './PriceDisplay.astro';
import Badge from '../atoms/Badge.astro';
import { formatCurrency } from '../../utils/formatters.ts';

interface Props {
  id:              string;
  name:            string;
  category:        string;
  price:           number;
  originalPrice?:  number;
  badges?:         Array<'new' | 'sale' | 'limited' | 'featured'>;
  image?:          string;
  aspectRatio?:    string;
  featured?:       boolean;
  animationDelay?: number;
}

const {
  id,
  name,
  category,
  price,
  originalPrice,
  badges         = [],
  image,
  aspectRatio    = '4/5',
  featured       = false,
  animationDelay = 0,
} = Astro.props;

const discount = originalPrice ? Math.round((1 - price / originalPrice) * 100) : null;
---

<article
  class:list={[
    "group relative bg-white rounded-f2-lg overflow-hidden shadow-f2-rest animate-card-in f2-transition hover:-translate-y-1 hover:shadow-f2-hover",
    featured ? "product-card--featured" : ""
  ]}
  style={`animation-delay: ${animationDelay}ms`}
  data-product-id={id}
>
  <a href={`/product/${id}`} class="absolute inset-0 z-0 select-none cursor-pointer" aria-label={`Ver detalles de ${name}`}></a>

  <div class="relative overflow-hidden bg-sand-100 pointer-events-none" style={`aspect-ratio: ${aspectRatio}`}>
    <div class="w-full h-full flex items-center justify-center transition-transform duration-600 ease-fluent group-hover:scale-105">
      {image ? (
        <img src={image} alt={name} loading="lazy" width="400" height="500" class="w-full h-full object-cover" />
      ) : (
        <slot name="image" />
      )}
    </div>

    {/* Badges */}
    {badges.length > 0 && (
      <div class="absolute top-3 left-3 flex flex-col gap-2 z-10">
        {badges.map((b) => (
          <Badge variant={b} label={
            b === 'sale' && discount ? `-${discount}%` :
            b === 'new'  ? 'Nuevo'     :
            b === 'limited' ? 'Limitado' : 'Destacado'
          } />
        ))}
      </div>
    )}

    {/*
      Wishlist Button:
      - Desktop: aparece solo en hover
      - Mobile (@media hover:none): siempre visible
    */}
    <button
      class="
        absolute top-3 right-3 w-10 h-10 rounded-full flex items-center justify-center z-10
        fluent-acrylic border-none text-sand-900/50 f2-transition
        hover:scale-110 hover:bg-white! hover:text-watermelon
        [&.is-active]:text-watermelon [&.is-active]:bg-white
        opacity-0 -translate-y-2
        group-hover:opacity-100 group-hover:translate-y-0
        [@media(hover:none)]:opacity-100 [@media(hover:none)]:translate-y-0
      "
      aria-label={`Guardar ${name} en favoritos`}
      data-wishlist-btn={id}
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="transition-colors">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
      </svg>
    </button>

    {/*
      Add to Cart Button:
      - Desktop: aparece en hover (overlay desde abajo)
      - Mobile (@media hover:none): siempre visible, texto más corto
    */}
    <div class="
      absolute bottom-0 left-0 right-0 p-2.5
      opacity-0 translate-y-2
      group-hover:opacity-100 group-hover:translate-y-0
      [@media(hover:none)]:opacity-100 [@media(hover:none)]:translate-y-0
      transition-all duration-300 ease-fluent z-10
    ">
      <button
        class="
          w-full h-10 bg-petrol/90 backdrop-blur-md text-white rounded-f2-md
          font-sans text-[12px] tracking-[0.08em] uppercase font-medium
          flex items-center justify-center gap-2
          cursor-pointer border-none transition-colors duration-150
          hover:bg-petrol active:scale-[0.97]
        "
        data-add-to-cart={id}
        aria-label={`Agregar ${name} al carrito`}
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <line x1="12" y1="5" x2="12" y2="19"/>
          <line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        <span class="hidden [@media(hover:none)]:hidden sm:inline">Agregar</span>
        <span class="[@media(hover:none)]:inline hidden sm:hidden">+</span>
      </button>
    </div>
  </div>

  <div class="p-4 pt-5 pb-6 flex flex-col h-full pointer-events-none">
    <div class="mb-3 grow">
      <p class="text-[10px] tracking-widest uppercase text-sand-900/40 mb-1.5 font-sans font-bold">{category}</p>
      <h3 class="text-[15px] font-display font-semibold text-sand-900 leading-[1.3] transition-colors duration-150 group-hover:text-petrol line-clamp-2 italic">{name}</h3>
    </div>
    <div class="mt-auto pt-3 flex flex-col gap-1.5">
      <PriceDisplay 
        price={price} 
        compareAtPrice={originalPrice} 
        showInstallments={true} 
        installmentsCount={price > 15000 ? 6 : 3} 
        size="md" 
      />
      {price > 20000 && (
        <span class="text-[11px] font-semibold text-petrol mt-1 flex items-center gap-1">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" class="text-success">
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
          </svg>
          Envío gratis a todo el país
        </span>
      )}
    </div>
  </div>
</article>

<script>
  import { wishlistItems, toggleWishlistItem } from '../../store/wishlist';

  const syncWishlistUI = () => {
    const items = wishlistItems.get();
    document.querySelectorAll('[data-wishlist-btn]').forEach((btn) => {
      const id = (btn as HTMLElement).dataset.wishlistBtn;
      if (id) {
        const isActive = !!items[id];
        const svg = btn.querySelector('svg');
        if (isActive) {
          btn.classList.add('is-active');
          svg?.setAttribute('fill', 'currentColor');
        } else {
          btn.classList.remove('is-active');
          svg?.setAttribute('fill', 'none');
        }
      }
    });
  };

  wishlistItems.subscribe(() => syncWishlistUI());

  document.addEventListener('astro:page-load', () => {
    syncWishlistUI();

    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;

      const wishlistBtn = target.closest('[data-wishlist-btn]');
      if (wishlistBtn) {
        e.preventDefault();
        e.stopPropagation();
        const id = (wishlistBtn as HTMLElement).dataset.wishlistBtn;
        if (id) toggleWishlistItem(id);
        return;
      }

      const cartBtn = target.closest('[data-add-to-cart]');
      if (cartBtn) {
        e.preventDefault();
        e.stopPropagation();
        const id = (cartBtn as HTMLElement).dataset.addToCart;
        if (id) {
          window.dispatchEvent(new CustomEvent('cart:add', { detail: { id } }));
        }
      }
    }, { once: false });
  }, { once: false });
</script>