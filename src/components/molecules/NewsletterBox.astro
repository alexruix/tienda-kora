---
/**
 * NewsletterBox.astro — Molecule
 * BeautyHome / KORA · NODO Studio
 *
 * Formulario de captura de leads. Ideal para el pre-footer.
 */

import Input from '../atoms/Input.astro';
import Button from '../atoms/Button.astro';

interface Props {
  title?: string;
  description?: string;
  placeholder?: string;
  buttonLabel?: string;
  class?: string;
}

const { 
  title = "Unite al Club KORA", 
  description = "Enterate antes que nadie de los ingresos de autor y repunte de esenciales.",
  placeholder = "Tu correo electrónico",
  buttonLabel = "Suscribirse",
  class: extraClass = '' 
} = Astro.props;
---

<div class:list={["bg-petrol rounded-f2-lg p-8 md:p-12 text-center", extraClass]}>
  <h3 class="font-display text-3xl font-light text-white mb-2">{title}</h3>
  <p class="font-sans text-[14px] text-white/70 mb-8 max-w-[400px] mx-auto">{description}</p>
  
  <form class="flex flex-col sm:flex-row gap-4 max-w-[500px] mx-auto" onsubmit="event => event.preventDefault();">
    <div class="flex-1 text-left">
      <Input 
        type="email" 
        id="newsletter-email" 
        name="email"
        placeholder={placeholder} 
        required 
        aria-label={placeholder}
        class="bg-white/10 text-white border-white/20 hover:border-white/40 focus:border-white placeholder:text-white/40"
      />
    </div>
    <Button type="submit" variant="primary" class="bg-white! text-petrol! hover:bg-sand-100!">
      {buttonLabel}
    </Button>
  </form>
</div>
