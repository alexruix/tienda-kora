---
/**
 * SupplierBadge.astro — Molecule
 * BeautyHome / KORA · NODO Studio
 *
 * Resalta el proveedor o el origen local (La Plata) para reforzar 
 * el valor de curaduría del mix 70/30.
 */

interface Props {
  supplier: string;
  isLocal?: boolean;
  class?: string;
}

const { supplier, isLocal = false, class: extraClass = '' } = Astro.props;
---

<div class:list={["inline-flex items-center gap-1.5 px-3 py-1.5 rounded-f2-sm font-sans text-[11px] font-medium tracking-[0.05em] uppercase", isLocal ? "bg-petrol/10 text-petrol" : "bg-sand-200 text-sand-900/70", extraClass]}>
  {isLocal ? (
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="shrink-0" aria-hidden="true">
      <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
      <circle cx="12" cy="10" r="3"></circle>
    </svg>
  ) : (
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="shrink-0" aria-hidden="true">
      <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
      <polyline points="9 22 9 12 15 12 15 22"></polyline>
    </svg>
  )}
  <span>{supplier}</span>
</div>
