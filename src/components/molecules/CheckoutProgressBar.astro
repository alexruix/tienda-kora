---
/**
 * CheckoutProgressBar.astro — Molecule
 * KORA · NODO Studio
 *
 * Barra de progreso del flujo de checkout.
 * Sticky en la parte superior, debajo del Navbar.
 * Props:
 *   step: 1 | 2 | 3 (Datos / Pago / Confirmación)
 */

interface Props {
  step: 1 | 2 | 3;
}

const { step } = Astro.props;

const steps = [
  { id: 1, label: 'Tus Datos',    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z' },
  { id: 2, label: 'Pago',         icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z' },
  { id: 3, label: 'Confirmación', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
];
---

<div class="fixed top-[92px] left-0 right-0 z-400 bg-sand-50/80 backdrop-blur-md border-b border-sand-200 shadow-sm">
  <div class="max-w-[800px] mx-auto px-5 py-3">
    <div class="flex items-center justify-between gap-0">
      {steps.map((s, i) => {
        const isCompleted = step > s.id;
        const isActive    = step === s.id;
        const isLast      = i === steps.length - 1;

        return (
          <div class="flex items-center flex-1">
            {/* Step item */}
            <div class:list={[
              "flex flex-col items-center gap-1 min-w-[60px]",
              isActive ? "text-petrol" : isCompleted ? "text-green-600" : "text-sand-900/30"
            ]}>
              {/* Circle */}
              <div class:list={[
                "w-8 h-8 rounded-full flex items-center justify-center border-2 transition-all duration-300",
                isCompleted
                  ? "bg-green-600 border-green-600 text-white"
                  : isActive
                    ? "bg-petrol border-petrol text-white"
                    : "bg-white border-sand-200 text-sand-900/30"
              ]}>
                {isCompleted ? (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                ) : (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d={s.icon} />
                  </svg>
                )}
              </div>

              {/* Label */}
              <span class:list={[
                "font-sans text-[10px] uppercase tracking-widest font-semibold text-center leading-tight",
                isActive ? "text-petrol" : isCompleted ? "text-green-600" : "text-sand-900/30"
              ]}>
                {s.label}
              </span>
            </div>

            {/* Connector line (no en el último step) */}
            {!isLast && (
              <div class="flex-1 h-[2px] mx-2 relative overflow-hidden rounded-full bg-sand-200">
                <div
                  class:list={[
                    "absolute inset-y-0 left-0 rounded-full transition-all duration-500",
                    isCompleted ? "w-full bg-green-600" : "w-0 bg-petrol"
                  ]}
                />
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</div>
