---
/**
 * ShippingInfo Molecule
 * KORA · NODO Studio
 * 
 * Componente informativo para explicar los tiempos de despacho,
 * especialmente para productos con táctica de "Batching" (Waw Pets).
 */

interface Props {
  brand?: string;
  leadTime?: string;
}

const { brand, leadTime } = Astro.props;

// Lógica de cálculo del próximo lunes para Waw Pets
const getNextMonday = () => {
    const d = new Date();
    const day = d.getDay();
    const diff = (day === 0 ? 1 : 8 - day);
    d.setDate(d.getDate() + diff);
    return d.toLocaleDateString('es-AR', { day: 'numeric', month: 'long' });
};

const nextDispatchDate = getNextMonday();
const isWawPets = brand === "Waw Pets";
---

<div class="mt-6 p-4 rounded-2xl bg-sand-50 border border-sand-200 flex gap-4 items-start shadow-sm f2-transition hover:border-petrol/20">
    <div class="p-2 rounded-xl bg-white shadow-f2-rest text-petrol">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
        </svg>
    </div>
    
    <div class="flex flex-col gap-1">
        <h4 class="text-[12px] font-bold uppercase tracking-widest text-sand-900">
            {isWawPets ? "Tanda Semanal Activa" : "Tiempo de Entrega"}
        </h4>
        <p class="text-[14px] text-sand-700 leading-relaxed">
            {isWawPets ? (
                <>Este producto de autor se despacha en la próxima tanda del <span class="font-bold text-petrol">lunes {nextDispatchDate}</span>.</>
            ) : (
                leadTime || "Entrega estimada en 2-5 días hábiles."
            )}
        </p>
        <p class="text-[11px] text-sand-500 font-medium italic">
            {isWawPets ? "¡Te avisaremos apenas tu pieza esté en camino!" : "Seguimiento disponible post-despacho."}
        </p>
    </div>
</div>
