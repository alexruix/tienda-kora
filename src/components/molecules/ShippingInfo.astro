---
/**
 * ShippingInfo.astro — Molecule
 * BeautyHome / KORA · NODO Studio
 *
 * Muestra los tiempos de entrega (leadTime) y la info de logística
 * clave para la estrategia híbrida de KORA (Micro-stock vs Cross-docking).
 */

interface Props {
  leadTime?: string;
  shippingMode?: string;
  class?: string;
}

const { 
  leadTime = "24-48 hs", 
  shippingMode = "Despacho inmediato",
  class: extraClass = '' 
} = Astro.props;
---

<div class:list={["flex items-start gap-3 p-3 rounded-f2-md bg-sand-100 border border-sand-200", extraClass]}>
  <div class="mt-0.5 text-petrol shrink-0" aria-hidden="true">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="1" y="3" width="15" height="13"></rect>
      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
      <circle cx="5.5" cy="18.5" r="2.5"></circle>
      <circle cx="18.5" cy="18.5" r="2.5"></circle>
    </svg>
  </div>
  <div>
    <p class="font-sans text-[13px] font-medium text-petrol mb-0.5">Llega en {leadTime}</p>
    <p class="font-sans text-[12px] text-sand-900/60 leading-tight">{shippingMode}</p>
  </div>
</div>
