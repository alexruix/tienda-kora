---
/**
 * Star.astro — Atom
 * BeautyHome / KORA · NODO Studio
 *
 * Estrella para ratings, soporta entera, media o vacía.
 */

interface Props {
  fill?: 'full' | 'half' | 'empty';
  size?: number | string;
  class?: string;
}

const { 
  fill = 'full', 
  size = 16,
  class: extraClass = '' 
} = Astro.props;

const path = "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z";
---

<svg 
  width={size} 
  height={size} 
  viewBox="0 0 24 24" 
  stroke="currentColor"
  stroke-width="1.5"
  fill={fill === 'empty' ? 'none' : 'currentColor'}
  class:list={["text-watermelon", fill === 'half' && "opacity-50", extraClass]}
  aria-hidden="true"
>
  <path d={path}></path>
</svg>
