---
/**
 * TrustItem Atom — Ítem del Trust Band (ícono SVG + título + subtítulo)
 * BeautyHome · NODO Studio
 *
 * Uso:
 *   <TrustItem icon="shipping" title="Free Shipping" sub="On orders over $50k" />
 */

interface Props {
  icon:    "shipping" | "returns" | "artisan" | "sustainable";
  title:   string;
  sub:     string;
  class?:  string;
}

const { icon, title, sub, class: extraClass = "" } = Astro.props;

// SVG paths para cada icono — semánticamente correctos, accesibles
const ICONS: Record<string, string> = {
  shipping: `
    <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/>
    <rect x="9" y="11" width="14" height="10" rx="2"/>
    <circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
  `,
  returns: `
    <polyline points="1 4 1 10 7 10"/>
    <path d="M3.51 15a9 9 0 1 0 .49-3.89"/>
  `,
  artisan: `
    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
    <circle cx="9" cy="7" r="4"/>
    <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"/>
  `,
  sustainable: `
    <path d="M2 13a11 11 0 0 0 20.83-3H2z"/>
    <path d="M5.6 6.6C7.2 4.3 9.5 2.8 12 2a11 11 0 0 1 10.83 8H2"/>
  `,
};
---

<div class:list={["flex items-center gap-4", extraClass]} role="listitem">
  <div
    class="w-11 h-11 rounded-f2-md bg-white shadow-f2-rest flex items-center justify-center shrink-0"
    aria-hidden="true"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="text-petrol"
      set:html={ICONS[icon]}
    />
  </div>
  <div class="font-sans">
    <p class="text-[13px] font-medium text-sand-900">{title}</p>
    <p class="text-[12px] text-sand-900/60 mt-0.5">{sub}</p>
  </div>
</div>
