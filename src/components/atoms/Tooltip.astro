---
/**
 * Tooltip Atom — Fluent 2
 * BeautyHome · NODO Studio
 */

interface Props {
  text:      string;
  position?: 'top' | 'bottom' | 'left' | 'right';
  class?:    string;
}

const {
  text,
  position  = 'top',
  class: extraClass = '',
} = Astro.props;

// Mapeo de posiciones para las clases de Tailwind
const positionClasses = {
  top:    "bottom-[calc(100%+8px)] left-1/2 -translate-x-1/2 translate-y-1 group-hover:translate-y-0 after:top-full after:left-1/2 after:-translate-x-1/2 after:border-t-sand-900",
  bottom: "top-[calc(100%+8px)] left-1/2 -translate-x-1/2 -translate-y-1 group-hover:translate-y-0 after:bottom-full after:left-1/2 after:-translate-x-1/2 after:border-b-sand-900",
  left:   "right-[calc(100%+8px)] top-1/2 -translate-y-1/2 translate-x-1 group-hover:translate-x-0 after:left-full after:top-1/2 after:-translate-y-1/2 after:border-l-sand-900",
  right:  "left-[calc(100%+8px)] top-1/2 -translate-y-1/2 -translate-x-1 group-hover:translate-x-0 after:right-full after:top-1/2 after:-translate-y-1/2 after:border-r-sand-900",
};
---

<div class:list={["group relative inline-flex", extraClass]} role="tooltip">
  <slot />
  
  <span 
    class:list={[
      "pointer-events-none absolute z-[9999] opacity-0 transition-all duration-200 ease-out",
      "group-hover:opacity-100 group-focus-within:opacity-100",
      "bg-sand-900 text-white text-[11px] font-medium px-2.5 py-1 rounded-f2-sm shadow-f2-rest whitespace-nowrap",
      "after:content-[''] after:absolute after:border-[5px] after:border-transparent",
      positionClasses[position]
    ]}
    aria-hidden="true"
  >
    {text}
  </span>
</div>