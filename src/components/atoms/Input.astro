---
/**
 * Input Atom — Fluent 2
 * BeautyHome · NODO Studio
 */

interface Props {
  type?:        'text' | 'email' | 'password' | 'search' | 'tel' | 'number';
  name?:        string;
  id?:          string;
  placeholder?: string;
  value?:       string;
  label?:       string;
  error?:       string;
  required?:    boolean;
  disabled?:    boolean;
  class?:       string;
  [key: string]: any;
}

const {
  type        = 'text',
  name,
  id,
  placeholder,
  value,
  label,
  error,
  required    = false,
  disabled    = false,
  class: extraClass = '',
  ...rest
} = Astro.props;

const inputId = id ?? name;

// Clases base del input para no repetir lógica
const inputClasses = [
  "w-full h-[42px] px-4 font-sans text-sm text-sand-900 bg-white outline-none transition-all duration-200",
  "border-[1.5px] rounded-f2-md",
  // Estado Normal
  "border-sand-200",
  // Hover & Focus (Fluent 2)
  "hover:border-sand-300 focus:border-petrol focus:ring-4 focus:ring-petrol/10",
  // Error state
  error ? "border-danger focus:border-danger focus:ring-danger/10" : "",
  // Disabled state
  "disabled:opacity-50 disabled:cursor-not-allowed disabled:bg-sand-100"
];
---

<div class:list={["flex flex-col gap-1.5 w-full group", extraClass]}>
  {label && (
    <label 
      for={inputId} 
      class:list={[
        "text-[12px] font-medium tracking-tight flex items-center gap-1 transition-colors",
        error ? "text-danger" : "text-sand-900/70 group-focus-within:text-petrol"
      ]}
    >
      {label}
      {required && <span class="text-danger" aria-hidden="true">*</span>}
    </label>
  )}

  <input
    type={type}
    id={inputId}
    name={name}
    placeholder={placeholder}
    value={value}
    required={required}
    disabled={disabled}
    class:list={inputClasses}
    aria-describedby={error ? `${inputId}-error` : undefined}
    aria-invalid={error ? 'true' : undefined}
    {...rest}
  />

  {error && (
    <span 
      id={`${inputId}-error`} 
      class="text-[12px] text-danger font-medium flex items-center gap-1 animate-acrylic-in" 
      role="alert"
    >
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {error}
    </span>
  )}
</div>