---
/**
 * StatusDot.astro — Atom
 * BeautyHome / KORA · NODO Studio
 *
 * Indicador visual para estado de stock, disponibilidad o estado de cuenta.
 */

interface Props {
  status: 'success' | 'warning' | 'error' | 'neutral';
  pulse?: boolean;
  class?: string;
}

const { 
  status = 'neutral', 
  pulse = false,
  class: extraClass = '' 
} = Astro.props;

const colorClasses = {
  success: 'bg-green-500',    // Stock disponible
  warning: 'bg-yellow-500',   // Poco stock / Preventa
  error: 'bg-watermelon',     // Agotado
  neutral: 'bg-sand-400',     // Default
};
---

<span class="relative flex h-2.5 w-2.5">
  {pulse && (
    <span class:list={["animate-ping absolute inline-flex h-full w-full rounded-full opacity-75", colorClasses[status]]}></span>
  )}
  <span class:list={["relative inline-flex rounded-full h-2.5 w-2.5", colorClasses[status], extraClass]}></span>
</span>
