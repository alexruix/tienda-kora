---
/**
 * Footer Organism
 * BeautyHome · NODO Studio
 *
 * Static server-rendered — no client JS needed.
 */

const NAV_COLUMNS = [
  {
    title: 'Shop',
    links: ['Living Room', 'Dining Room', 'Workspace', 'New Arrivals', 'Sale'],
  },
  {
    title: 'About',
    links: ['Our Philosophy', 'NODO Studio', 'Artisan Partners', 'Sustainability', 'Press'],
  },
  {
    title: 'Support',
    links: ['Shipping & Returns', 'Track My Order', 'Care Instructions', 'Design Consultancy', 'Contact Us'],
  },
];

function slugify(s: string) {
  return s.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '');
}
---

<footer class="bg-petrol-dark text-white/55 pt-16 pb-8">
  <div class="max-w-[1320px] mx-auto px-8">

    <div class="grid grid-cols-2 lg:grid-cols-[2fr_1fr_1fr_1fr] gap-8 lg:gap-12 pb-12 border-b border-white/10">

      <div class="col-span-2 lg:col-span-1">
        <p class="font-display text-[30px] font-light tracking-[0.1em] text-white uppercase mb-4">BeautyHome</p>
        <p class="text-[14px] leading-[1.7] text-white/40 max-w-[300px] mb-6">
          A curated atelier for high-end home décor — bringing together the finest
          artisan studios from Japan, Scandinavia, and Southern Europe.
        </p>

        <div class="mb-6">
          <p class="text-[11px] tracking-[0.14em] uppercase text-white/35 mb-3">Join the inner circle</p>
          <form class="flex h-10 mb-6" action="/newsletter" method="POST">
            <input
              type="email"
              name="email"
              placeholder="your@email.com"
              class="flex-1 px-4 font-sans text-[13px] bg-white/5 border border-white/10 border-r-0 rounded-l-f2-md text-white outline-none transition-colors duration-200 placeholder:text-white/25 focus:border-white/25 focus:bg-white/10"
              required
              aria-label="Email for newsletter"
            />
            <button type="submit" class="w-11 bg-watermelon border-none rounded-r-f2-md text-white flex items-center justify-center cursor-pointer transition-colors duration-200 shrink-0 hover:bg-watermelon-hover" aria-label="Subscribe">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          </form>
        </div>

        <div class="flex gap-3" role="list" aria-label="Social media">
          <a href="https://instagram.com" class="w-9 h-9 rounded-f2-md bg-white/5 flex items-center justify-center text-white/50 no-underline transition-all duration-200 hover:bg-white/10 hover:text-white/85 hover:-translate-y-0.5" target="_blank" rel="noopener" title="Instagram" role="listitem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
            </svg>
          </a>
          <a href="https://pinterest.com" class="w-9 h-9 rounded-f2-md bg-white/5 flex items-center justify-center text-white/50 no-underline transition-all duration-200 hover:bg-white/10 hover:text-white/85 hover:-translate-y-0.5" target="_blank" rel="noopener" title="Pinterest" role="listitem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.04-2.83.18-.76 1.23-5.2 1.23-5.2s-.31-.63-.31-1.56c0-1.46.85-2.55 1.9-2.55.9 0 1.33.67 1.33 1.48 0 .9-.58 2.26-.87 3.51-.25 1.05.52 1.9 1.54 1.9 1.85 0 3.27-1.95 3.27-4.77 0-2.49-1.79-4.23-4.35-4.23-2.96 0-4.7 2.22-4.7 4.52 0 .9.35 1.86.78 2.38.07.08.09.16.07.3-.08.33-.26 1.05-.29 1.19-.05.19-.16.23-.37.14-1.39-.65-2.26-2.68-2.26-4.32 0-3.51 2.55-6.74 7.35-6.74 3.86 0 6.86 2.75 6.86 6.42 0 3.83-2.41 6.9-5.75 6.9-1.12 0-2.18-.58-2.54-1.27l-.69 2.59c-.25.97-.93 2.18-1.38 2.92.52.16 1.07.25 1.62.25 5.52 0 10-4.48 10-10S17.52 2 12 2z"/>
            </svg>
          </a>
          <a href="https://linkedin.com" class="w-9 h-9 rounded-f2-md bg-white/5 flex items-center justify-center text-white/50 no-underline transition-all duration-200 hover:bg-white/10 hover:text-white/85 hover:-translate-y-0.5" target="_blank" rel="noopener" title="LinkedIn" role="listitem">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
              <rect x="2" y="9" width="4" height="12"/>
              <circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
        </div>
      </div>

      {NAV_COLUMNS.map((col) => (
        <nav aria-label={col.title}>
          <p class="text-[11px] tracking-[0.16em] uppercase text-white/35 mb-5 font-medium">{col.title}</p>
          <ul class="flex flex-col gap-3 list-none p-0 m-0">
            {col.links.map((link) => (
              <li>
                <a href={`/${slugify(link)}`} class="text-[14px] text-white/50 no-underline transition-colors duration-200 leading-[1.4] hover:text-white/85">{link}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between pt-8 text-[13px] text-white/30 flex-wrap gap-4">
      <span>© {new Date().getFullYear()} BeautyHome · All rights reserved</span>
      
      <div class="flex flex-wrap gap-3 sm:gap-5">
        <a href="/privacy" class="text-[12px] text-white/30 no-underline transition-colors duration-200 hover:text-white/60">Privacy Policy</a>
        <a href="/terms"   class="text-[12px] text-white/30 no-underline transition-colors duration-200 hover:text-white/60">Terms of Use</a>
        <a href="/cookies" class="text-[12px] text-white/30 no-underline transition-colors duration-200 hover:text-white/60">Cookie Settings</a>
      </div>
      
      <div class="flex items-center gap-2 text-[12px] text-white/30">
        <div class="w-[26px] h-[26px] rounded-f2-sm bg-white/10 flex items-center justify-center text-[10px] tracking-[0.04em] text-white/40 font-semibold font-sans" aria-hidden="true">NO</div>
        Designed at NODO Studio
      </div>
    </div>

  </div>
</footer>