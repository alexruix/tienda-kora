---
/**
 * CategorySidebar.astro — Organism
 * BeautyHome / KORA · NODO Studio
 *
 * Panel lateral para las vistas de catálogo.
 * Agrupa filtros (marcas, categorías anidadas, precios) usando FilterSidebarGroup.
 */

import FilterSidebarGroup from '../molecules/FilterSidebarGroup.astro';

interface Props {
  class?: string;
}

const { class: extraClass = '' } = Astro.props;

const categories = [
  { id: 'ropa', label: 'Indumentaria Pet', count: 32 },
  { id: 'accesorios', label: 'Accesorios y Paseo', count: 19 },
  { id: 'living', label: 'Descanso', count: 12 },
  { id: 'dining', label: 'Alimentación', count: 5 },
  { id: 'workspace', label: 'Juego', count: 18 },
  { id: 'bienestar', label: 'Bienestar', count: 8 },
];

const brands = [
  { id: 'waw-pet', label: 'Waw Pets' },
  { id: 'don-orione', label: 'Don Orione' },
  { id: 'mon-ami', label: 'Mon Ami' },
  { id: 'pedidos-ya', label: 'Pedidos Ya' },
];
---

<aside class:list={["w-full lg:w-[260px] shrink-0", extraClass]}>
  <div class="lg:sticky lg:top-[120px] pr-0 lg:pr-6">
    <div class="flex items-center justify-between lg:hidden mb-6 pb-4 border-b border-sand-200">
      <h2 class="font-sans text-[16px] font-semibold text-petrol">Filtros</h2>
      <button class="text-[12px] uppercase tracking-widest text-sand-500 underline">Limpiar</button>
    </div>

    <form class="flex flex-col">
      <FilterSidebarGroup title="Tipos de Producto" options={categories} type="checkbox" />
      <FilterSidebarGroup title="Nuestros Aliados" options={brands} type="checkbox" />
    </form>
  </div>
</aside>
