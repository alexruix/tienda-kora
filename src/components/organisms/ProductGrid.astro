---
/**
 * ProductGrid Organism
 * BeautyHome · NODO Studio
 */

import ProductCard from '../molecules/ProductCard.astro';
import Button from '../atoms/Button.astro';

interface Product {
  id:             string;
  name:           string;
  category:       string;
  price:          number;
  originalPrice?: number;
  rating?:        number;
  reviewCount?:   number;
  badges?:        Array<'new' | 'sale' | 'limited' | 'featured'>;
  image?:         string;
}

interface Props {
  products:     Product[];
  layout?:      'default' | 'featured' | 'dense';
  title?:       string;
  label?:       string;
  subtitle?:    string;
  showFilters?: boolean;
  showSort?:    boolean;
  ctaLabel?:    string;
  ctaHref?:     string;
}

const {
  products,
  layout      = 'default',
  title,
  label,
  subtitle,
  showFilters = false,
  showSort    = false,
  ctaLabel,
  ctaHref     = '#',
} = Astro.props;

const uniqueCategories = [...new Set(products.map(p => p.category?.split(' · ')[0] || p.category))].filter(Boolean);
const FILTERS = ['Todos', ...uniqueCategories];

const SORT_OPTIONS = [
  { value: 'featured',   label: 'Ordenar: Destacados'    },
  { value: 'price-asc',  label: 'Precio: Menor a Mayor'  },
  { value: 'price-desc', label: 'Precio: Mayor a Menor'  },
  { value: 'newest',     label: 'Más nuevos'             },
  { value: 'top-rated',  label: 'Mejor valorados'        },
];
---

<section data-product-grid>
  {(title || label) && (
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
      <div>
        {label && <p class="text-xs tracking-[0.2em] uppercase text-sand-900/50 mb-2">{label}</p>}
        {title && <h2 class="font-sans text-4xl font-light text-petrol" set:html={title} />}
        {subtitle && <p class="text-base text-sand-900/70 mt-3 max-w-2xl">{subtitle}</p>}
      </div>
      {ctaLabel && (
        <div class="shrink-0">
          <Button variant="secondary" href={ctaHref}>{ctaLabel}</Button>
        </div>
      )}
    </div>
  )}

  {showFilters && (
    <div class="flex flex-col gap-4 mb-8">
      {/* Top Toolbar: Switch + Sort + Mobile Filter Btn */}
      <div class="flex items-center justify-between gap-4 py-3 border-y border-sand-200 flex-wrap" role="toolbar" aria-label="Product filters">
        
        {/* Fast Shipping Switch (Llega Mañana) */}
        <label class="flex items-center gap-3 cursor-pointer group">
          <div class="relative inline-flex items-center">
            <input type="checkbox" class="sr-only peer" />
            <div class="w-10 h-6 bg-sand-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-petrol/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-sand-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-600 f2-transition"></div>
          </div>
          <span class="font-sans text-[13px] font-bold text-petrol group-hover:text-green-600 f2-transition flex items-center gap-1.5">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="text-green-600">
              <path d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
            Llega mañana
          </span>
        </label>

        {/* Category Filter Pills (Desktop & Tablet) */}
        <div class="hidden md:flex flex-wrap gap-2 items-center" role="group" aria-label="Categorías">
          {FILTERS.map((cat) => (
            <button
              class={`filter-pill ${cat === 'Todos' ? 'filter-pill--active' : ''}`}
              data-filter={cat}
              aria-pressed={cat === 'Todos' ? 'true' : 'false'}
            >
              {cat}
            </button>
          ))}
        </div>

        {/* Right side: Filter Btn (Mobile) + Sort (Desktop) */}
        <div class="flex items-center gap-3 ml-auto">
          {/* Mobile Filter Button */}
          <button class="lg:hidden flex items-center gap-2 font-sans font-medium text-[13px] text-petrol bg-sand-100 px-4 py-2 rounded-full border border-sand-200">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
            </svg>
            Filtrar
          </button>

          {/* Sort Dropdown */}
          {showSort && (
            <div class="relative hidden lg:flex flex-items-center">
              <select class="sort-select border-none bg-transparent font-sans text-[13px] font-medium text-petrol cursor-pointer pr-6 appearance-none focus:ring-0" aria-label="Ordenar por">
                {SORT_OPTIONS.map((opt) => (
                  <option value={opt.value}>{opt.label}</option>
                ))}
              </select>
              <svg class="absolute right-0 pointer-events-none text-sand-900/40 mt-1" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M6 9l6 6 6-6"/>
              </svg>
            </div>
          )}

          {/* View Toggles */}
          <div class="hidden md:flex gap-1 border-l border-sand-200 pl-3 ml-1" role="group" aria-label="View style">
            <button class="view-btn view-btn--active text-petrol" data-view="grid" aria-label="Grid view" aria-pressed="true">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                <rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/>
              </svg>
            </button>
            <button class="view-btn text-sand-900/30 hover:text-petrol f2-transition" data-view="list" aria-label="List view" aria-pressed="false">
              <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor">
                <rect x="1" y="2" width="14" height="2.5" rx="1"/><rect x="1" y="6.75" width="14" height="2.5" rx="1"/><rect x="1" y="11.5" width="14" height="2.5" rx="1"/>
              </svg>
            </button>
          </div>
        </div>
      </div>

      {/* Active Filter Chips Strip */}
      <div class="flex flex-wrap gap-2 items-center" id="active-filters-container">
        {/* Chips will be rendered by JS if needed, or we can use this for specific active filters */}
        <div id="active-filter-chips" class="flex flex-wrap gap-2"></div>
        <button data-clear-all-filters class="hidden font-sans text-[11px] font-bold text-watermelon ml-2 bg-transparent border-none cursor-pointer tracking-wide hover:opacity-70 p-0">
          Limpiar todos
        </button>
      </div>
    </div>
  )}

  <div class={`product-grid product-grid--${layout}`} role="list">
    {products.map((product, index) => (
      <div 
        role="listitem" 
        class="product-item" 
        data-category={product.category?.split(' · ')[0] || product.category}
        data-price={product.price}
        data-rating={product.rating || 0}
        data-index={index}
        data-fast-shipping={product.price > 20000 ? "true" : "false"}
      >
        <ProductCard
          {...product}
          featured={layout === 'featured' && index === 0}
          aspectRatio={layout === 'featured' && index === 0 ? '4/5' : '4/5'}
          animationDelay={index * 50}
        />
      </div>
    ))}
  </div>
</section>

<script>
  function initGrids() {
    const gridContainers = document.querySelectorAll('[data-product-grid]');

    gridContainers.forEach((container) => {
      const grid = container.querySelector('.product-grid') as HTMLElement;
      const items = container.querySelectorAll('.product-item');
      const fastShippingToggle = container.querySelector('input[type="checkbox"]') as HTMLInputElement;
      const sortSelect = container.querySelector('.sort-select') as HTMLSelectElement;
      const clearBtn = container.querySelector('[data-clear-all-filters]') as HTMLElement;
      const categoryPills = container.querySelectorAll('.filter-pill');
      
      let currentCategory = 'Todos';
      let fastShippingOnly = false;

      const filterProducts = () => {
        items.forEach((item: any) => {
          const cat = item.dataset.category;
          const isFast = item.dataset.fastShipping === "true";
          
          const matchesCat = currentCategory === 'Todos' || cat === currentCategory;
          const matchesFast = !fastShippingOnly || isFast;

          item.style.display = (matchesCat && matchesFast) ? 'block' : 'none';
        });

        // Update pills UI
        categoryPills.forEach((p: any) => {
          const isActive = p.dataset.filter === currentCategory;
          p.classList.toggle('filter-pill--active', isActive);
          p.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        });

        if (clearBtn) {
          clearBtn.style.display = (currentCategory !== 'Todos' || fastShippingOnly) ? 'block' : 'none';
        }
      };

      // Filter by category
      categoryPills.forEach((pill) => {
        pill.addEventListener('click', () => {
          currentCategory = (pill as HTMLElement).dataset.filter || 'Todos';
          filterProducts();
        });
      });

      // Filter by fast shipping
      fastShippingToggle?.addEventListener('change', (e) => {
        fastShippingOnly = (e.target as HTMLInputElement).checked;
        filterProducts();
      });

      // Sort logic
      sortSelect?.addEventListener('change', (e) => {
        const val = (e.target as HTMLSelectElement).value;
        const sortedItems = Array.from(items).sort((a: any, b: any) => {
          if (val === 'price-asc') return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
          if (val === 'price-desc') return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
          if (val === 'top-rated') return parseFloat(b.dataset.rating) - parseFloat(a.dataset.rating);
          if (val === 'newest') return parseInt(b.dataset.index) - parseInt(a.dataset.index);
          return parseInt(a.dataset.index) - parseInt(b.dataset.index);
        });

        if (grid) {
          sortedItems.forEach(item => grid.appendChild(item));
        }
      });

      // Clear all
      clearBtn?.addEventListener('click', () => {
        currentCategory = 'Todos';
        fastShippingOnly = false;
        if (fastShippingToggle) fastShippingToggle.checked = false;
        filterProducts();
      });

      // View toggle
      container.querySelectorAll('.view-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          container.querySelectorAll('.view-btn').forEach((b) => {
            b.classList.remove('view-btn--active');
            b.setAttribute('aria-pressed', 'false');
          });
          btn.classList.add('view-btn--active');
          btn.setAttribute('aria-pressed', 'true');

          const view = (btn as HTMLElement).dataset.view;
          if (grid && view) {
            grid.dataset.viewMode = view;
          }
        });
      });
    });
  }

  document.addEventListener('astro:page-load', initGrids);
</script>