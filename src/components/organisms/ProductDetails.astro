---
/**
 * ProductDetails.astro — Organism
 * KORA · NODO Studio
 *
 * Núcleo del PDP. Integra señales de conversión al estilo MercadoLibre:
 * - StockBadge: urgencia de disponibilidad
 * - DeliveryEstimate: fecha real de entrega
 * - PriceDisplay: precio + descuento + cuotas
 * - Sticky CTA bar mobile (IntersectionObserver)
 */

import ProductGallery   from '../molecules/ProductGallery.astro';
import PriceDisplay     from '../molecules/PriceDisplay.astro';
import AttributeSelector from '../molecules/AttributeSelector.astro';
import DeliveryEstimate from '../molecules/DeliveryEstimate.astro';
import TrustBadgeGroup  from '../molecules/TrustBadgeGroup.astro';
import StockBadge       from '../atoms/StockBadge.astro';
import Separator        from '../atoms/Separator.astro';
import { QuantitySelector } from '../molecules/QuantitySelector.jsx';
import Button from '../atoms/Button.astro';
import { formatCurrency } from '../../utils/formatters.ts';

interface Props {
  product: any;
  class?: string;
}

const { product, class: extraClass = '' } = Astro.props;

const colors = product.variants?.map((v: any) => ({
  label: v.label,
  value: v.value,
  colorHex: v.color,
  available: v.available
})) || [];

const hasVariations = colors.length > 0;

// Calcular leadTime numérico desde el string (e.g. "24-48 hs" → 2 días hábiles)
const leadTimeDays = (() => {
  const lt = product.leadTime ?? '';
  if (lt.includes('24')) return 1;
  if (lt.includes('48')) return 2;
  if (lt.includes('72')) return 3;
  return 3; // default
})();

const shippingMode = product.shipping?.toLowerCase().includes('retiro') ? 'pickup' : 'standard';

const formattedPrice = formatCurrency(product.price);
---

<div class:list={["grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-[1320px] mx-auto px-5 md:px-8 py-12 pb-[100px] lg:pb-12", extraClass]}>
  
  {/* Left: Gallery */}
  <div>
    <ProductGallery 
      images={[
        { id: 'img-1', src: product.image, alt: product.name },
        ...(product.gallery || []).map((img: string, i: number) => ({
          id: `img-extra-${i}`,
          src: img,
          alt: `${product.name} - Detalle ${i + 1}`
        }))
      ]} 
    />
  </div>

  {/* Right: Info & Actions */}
  <div class="flex flex-col">

    {/* ── Eyebrow: nuevo + badges ── */}
    <div class="flex items-center gap-3 mb-4 flex-wrap">
      {product.newArrival && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-petrol text-white text-[10px] uppercase tracking-widest rounded-full font-semibold">
          ✦ Nuevo
        </span>
      )}
      <StockBadge stock={product.stock} />
    </div>

    <h1 class="font-display text-4xl lg:text-5xl font-light text-petrol mb-2 leading-tight">{product.name}</h1>
    <p class="font-sans text-[15px] text-sand-900/60 mb-5">{product.subtitle}</p>

    {/* ── Reseñas ── */}
    {product.rating && product.reviewCount && (
      <div class="flex items-center gap-2 mb-5">
        <div class="flex gap-0.5" aria-label={`${product.rating} de 5 estrellas`}>
          {Array.from({ length: 5 }).map((_, i) => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill={i < Math.round(product.rating) ? '#e67e22' : 'none'} stroke={i < Math.round(product.rating) ? '#e67e22' : '#ccc'} stroke-width="1.5">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>
        <span class="font-sans text-[13px] text-sand-900/60">{product.rating} ({product.reviewCount} reseñas)</span>
      </div>
    )}

    {/* ── Precio + Cuotas ── */}
    <PriceDisplay 
      price={product.price}
      compareAtPrice={product.originalPrice}
      showInstallments={true}
      installmentsCount={product.price > 15000 ? 6 : 3}
      size="lg"
      class="mb-5"
    />

    <Separator margin="sm" />

    {/* ── Variantes ── */}
    {hasVariations && (
      <div class="flex flex-col gap-6 mb-6">
        <AttributeSelector name="Color" options={colors} type="color" />
      </div>
    )}

    {/* ── Entrega Estimada (nuevo — clave para conversión) ── */}
    <DeliveryEstimate
      leadTime={leadTimeDays}
      shippingMode={shippingMode as any}
      class="mb-4"
    />

    {/* ── Envío gratis ── */}
    {product.price > 20000 && (
      <div class="flex items-center gap-2 text-[13px] text-petrol font-medium mb-6 bg-petrol/5 border border-petrol/10 rounded-f2-md px-4 py-2.5">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
        Envío gratis a todo el país en este producto
      </div>
    )}

    {/* ── CTA Principal ── */}
    <div id="pdp-cta-anchor" class="flex items-center gap-3 mb-6">
      <div class="w-[120px] shrink-0">
        <QuantitySelector client:load quantity={1} className="w-full" id="pdp-quantity" />
      </div>
      <Button 
        variant="primary" 
        class="flex-1 h-12 text-[13px] uppercase tracking-widest font-bold gap-2"
        data-add-to-cart={product.id}
      >
        Agregar al Carrito
      </Button>
      <button
        class="w-12 h-12 rounded-f2-md border border-sand-200 bg-white flex items-center justify-center text-sand-400 f2-transition hover:border-watermelon hover:text-watermelon group [&.is-active]:text-watermelon [&.is-active]:border-watermelon shrink-0"
        aria-label="Guardar en favoritos"
        data-wishlist-btn={product.id}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="transition-colors group-[.is-active]:fill-watermelon">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
        </svg>
      </button>
    </div>

    {/* ── Trust Strip ── */}
    <div class="grid grid-cols-3 gap-3 mb-6 py-4 border-y border-sand-200">
      {[
        { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', label: 'Compra Protegida' },
        { icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', label: 'Seguimento por Email' },
        { icon: 'M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15', label: 'Cambios en 30 días' },
      ].map(item => (
        <div class="flex flex-col items-center text-center gap-1.5">
          <div class="w-9 h-9 rounded-full bg-petrol/5 flex items-center justify-center text-petrol">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d={item.icon}/>
            </svg>
          </div>
          <span class="font-sans text-[10px] font-semibold text-sand-900/60 uppercase tracking-wider leading-tight">{item.label}</span>
        </div>
      ))}
    </div>

    <Separator margin="sm" />

    {/* ── Accordions de detalles ── */}
    <details class="group py-4 border-b border-sand-200 cursor-pointer">
      <summary class="flex justify-between items-center font-sans text-[13px] font-semibold tracking-[0.05em] uppercase text-petrol select-none list-none [&::-webkit-details-marker]:hidden">
        Descripción del Producto
        <span class="transition-transform duration-200 group-open:rotate-180 text-sand-900/30">▼</span>
      </summary>
      <p class="font-sans text-[14px] text-sand-900/70 leading-relaxed mt-4">
        {product.description}
      </p>
    </details>
    
    {product.details && product.details.length > 0 && (
      <details class="group py-4 border-b border-sand-200 cursor-pointer">
        <summary class="flex justify-between items-center font-sans text-[13px] font-semibold tracking-[0.05em] uppercase text-petrol select-none list-none [&::-webkit-details-marker]:hidden">
          Especificaciones
          <span class="transition-transform duration-200 group-open:rotate-180 text-sand-900/30">▼</span>
        </summary>
        <ul class="font-sans text-[14px] text-sand-900/70 leading-relaxed mt-4 flex flex-col gap-2">
          {product.details.map((d: any) => (
            <li class="flex gap-2">
              <span class="text-petrol">✦</span>
              <span><strong class="text-sand-900/80">{d.label}:</strong> {d.value}</span>
            </li>
          ))}
        </ul>
      </details>
    )}

  </div>
</div>

{/* ── Sticky CTA Bar (Mobile only) ── */}
<div
  id="pdp-sticky-cta"
  class="fixed bottom-0 inset-x-0 z-500 lg:hidden bg-white border-t border-sand-200 shadow-[0_-4px_24px_rgba(0,0,0,0.08)] translate-y-full transition-transform duration-300 ease-fluent"
  style="padding-bottom: env(safe-area-inset-bottom);"
  aria-hidden="true"
>
  <div class="flex items-center gap-3 px-5 py-3 h-[68px]">
    <div class="flex-1 min-w-0">
      <p class="font-sans text-[10px] uppercase tracking-widest text-sand-900/40 leading-none mb-0.5">Precio</p>
      <p class="font-display text-[22px] text-petrol leading-none font-light">{formattedPrice}</p>
    </div>
    <button
      id="pdp-sticky-add-btn"
      class="h-[48px] px-5 bg-petrol text-white rounded-f2-lg font-sans text-[12px] tracking-[0.06em] uppercase font-semibold flex items-center gap-2 border-none cursor-pointer shrink-0 transition-all active:scale-[0.98]"
      data-add-to-cart={product.id}
      aria-label={`Agregar ${product.name} al carrito`}
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
        <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
      </svg>
      Agregar
    </button>
    <button
      class="w-12 h-12 rounded-f2-md flex items-center justify-center text-sand-400 shrink-0 border border-sand-200 bg-white [&.is-active]:text-watermelon [&.is-active]:border-watermelon transition-colors"
      aria-label="Guardar en favoritos"
      data-wishlist-btn-sticky={product.id}
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  import { wishlistItems, toggleWishlistItem } from "../../store/wishlist";

  function initPDP() {
    // 1. Variantes
    const variantInputs = document.querySelectorAll('input[name="Color"]');
    variantInputs.forEach(input => {
      input.addEventListener('change', (e) => {
        const target = e.target as HTMLInputElement;
        console.log('Variante:', target.value);
      });
    });

    // 2. Carrito — botón principal
    document.querySelector("[data-add-to-cart]")?.addEventListener("click", (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.addToCart;
      const qEl = document.getElementById("pdp-quantity") as any;
      const qty = qEl?.__v_quantity || 1;
      if (id) window.dispatchEvent(new CustomEvent("cart:add", { detail: { id, quantity: qty } }));
    });

    // 3. Carrito — botón sticky
    const stickyBtn = document.getElementById("pdp-sticky-add-btn");
    stickyBtn?.addEventListener("click", () => {
      const id = stickyBtn.dataset.addToCart;
      if (id) {
        window.dispatchEvent(new CustomEvent("cart:add", { detail: { id, quantity: 1 } }));
        stickyBtn.textContent = "✓ Agregado";
        stickyBtn.classList.add("!bg-green-600");
        setTimeout(() => {
          stickyBtn.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg> Agregar`;
          stickyBtn.classList.remove("!bg-green-600");
        }, 2000);
      }
    });

    // 4. Wishlist — ambos botones
    const syncWishlist = () => {
      const items = wishlistItems.get();
      const ids = [
        { btn: document.querySelector("[data-wishlist-btn]"), key: 'wishlistBtn' },
        { btn: document.querySelector("[data-wishlist-btn-sticky]"), key: 'wishlistBtnSticky' },
      ];
      ids.forEach(({ btn }) => {
        if (!btn) return;
        const el = btn as HTMLElement;
        const id = el.dataset.wishlistBtn || el.dataset.wishlistBtnSticky;
        const active = id && items[id];
        btn.classList.toggle("is-active", !!active);
        btn.querySelector("svg")?.setAttribute("fill", active ? "currentColor" : "none");
      });
    };

    syncWishlist();
    wishlistItems.subscribe(syncWishlist);

    document.querySelector("[data-wishlist-btn]")?.addEventListener("click", (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.wishlistBtn;
      if (id) toggleWishlistItem(id);
    });
    document.querySelector("[data-wishlist-btn-sticky]")?.addEventListener("click", (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.wishlistBtnSticky;
      if (id) toggleWishlistItem(id);
    });

    // 5. Sticky CTA Bar — IntersectionObserver
    const anchor = document.getElementById("pdp-cta-anchor");
    const bar    = document.getElementById("pdp-sticky-cta");
    if (anchor && bar) {
      const obs = new IntersectionObserver(([entry]) => {
        const visible = entry.isIntersecting;
        bar.style.transform = visible ? "translateY(100%)" : "translateY(0)";
        bar.setAttribute("aria-hidden", visible ? "true" : "false");
      }, { threshold: 0, rootMargin: "0px 0px -20px 0px" });
      obs.observe(anchor);
    }
  }

  document.addEventListener("astro:page-load", initPDP);
</script>
