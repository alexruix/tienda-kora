---
/**
 * CategoryLayout.astro — Category Page Template
 * BeautyHome · NODO Studio
 */

import MainLayout from './MainLayout.astro';

interface Props {
  category:      'living' | 'dining' | 'workspace';
  title?:        string;
  description?:  string;
  productCount?: number;
}

const {
  category,
  title        = category.charAt(0).toUpperCase() + category.slice(1),
  description  = '',
  productCount = 0,
} = Astro.props;

const SIDEBAR_FILTERS: Record<string, { label: string; options: string[] }[]> = {
  living: [
    { label: 'Category',   options: ['Sofas','Chairs','Tables','Storage','Lighting','Décor'] },
    { label: 'Material',   options: ['Solid Wood','Upholstered','Metal','Ceramic','Rattan'] },
    { label: 'Style',      options: ['Japandi','Scandinavian','Wabi-Sabi','Minimalist'] },
    { label: 'Price',      options: ['Under $500','$500–$1,500','$1,500–$3,000','$3,000+'] },
  ],
  dining: [
    { label: 'Category',   options: ['Tables','Chairs','Benches','Sideboards','Bar Stools'] },
    { label: 'Seats',      options: ['2','4','6','8+','Extendable'] },
    { label: 'Material',   options: ['Oak','Walnut','Marble','Ceramic','Metal'] },
    { label: 'Price',      options: ['Under $800','$800–$2,500','$2,500+'] },
  ],
  workspace: [
    { label: 'Category',   options: ['Writing Desks','Standing Desks','Chairs','Shelving'] },
    { label: 'Material',   options: ['Oak','Walnut','Steel','Bamboo'] },
    { label: 'Price',      options: ['Under $500','$500–$1,500','$1,500+'] },
  ],
};

const HERO: Record<string, { eyebrow: string; headline: string; sub: string }> = {
  living:    { eyebrow: 'The Heart of Home', headline: 'Living <em>Spaces</em>', sub: 'Pieces chosen for their quiet confidence — where every object earns its place through beauty and utility.' },
  dining:    { eyebrow: 'Gather & Share',    headline: 'Dining <em>Ritual</em>',  sub: 'Tables and chairs that transform everyday meals into moments of quiet ceremony.' },
  workspace: { eyebrow: 'Focus & Flow',      headline: 'The Quiet <em>Workspace</em>', sub: 'Objects for clarity of thought — where the desk becomes a stage for focused presence.' },
};

const hero    = HERO[category] || HERO.living; // Fallback de seguridad
const filters = SIDEBAR_FILTERS[category] ?? [];
---

<MainLayout title={`${title} — BeautyHome`} description={description || hero.sub}>

  {/* ─── Category Hero ─── */}
  <div class="bg-sand-100/50 border-b border-sand-200 py-12 lg:py-16">
    <div class="max-w-[1320px] mx-auto px-5 md:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-6 animate-fade-in-up">
        <div class="max-w-2xl">
          <p class="font-sans text-[11px] tracking-[0.22em] uppercase text-watermelon mb-3 flex items-center gap-3 before:content-[''] before:w-6 before:h-px before:bg-watermelon">
            {hero.eyebrow}
          </p>
          <h1 class="font-display text-[clamp(40px,6vw,72px)] font-light text-petrol leading-[1.05] mb-4 [&>em]:font-italic [&>em]:text-sand-900/60" set:html={hero.headline} />
          <p class="font-sans text-[15px] text-sand-900/70 max-w-[480px] leading-[1.7]">
            {hero.sub}
          </p>
        </div>
        <span class="font-sans text-[13px] text-sand-900/50 shrink-0">
          {productCount} pieces
        </span>
      </div>

      {/* Breadcrumb */}
      <nav aria-label="Breadcrumb" class="mt-6">
        <ol class="flex items-center gap-2 font-sans text-[13px] text-sand-900/50 flex-wrap">
          <li><a href="/" class="hover:text-sand-900 f2-transition">Home</a></li>
          <li aria-hidden="true">›</li>
          <li aria-current="page" class="text-sand-900 font-medium">{title}</li>
        </ol>
      </nav>
    </div>
  </div>

  {/* ─── Layout: Sidebar + Grid ─── */}
  <div class="max-w-[1320px] mx-auto px-5 md:px-8 py-10 lg:py-16 grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-10 items-start">

    {/* Sidebar Filters */}
    <aside class="lg:sticky lg:top-[92px]" aria-label="Product filters">
      <div class="flex items-center justify-between mb-4">
        <p class="font-sans text-[11px] tracking-[0.16em] uppercase text-sand-900/50 font-medium">Refine</p>
        <button class="font-sans text-[11px] text-watermelon bg-transparent border-none cursor-pointer tracking-[0.04em] hover:opacity-70 f2-transition p-0">Clear all</button>
      </div>

      <div class="flex flex-col">
        {filters.map((group) => (
          <details class="group border-b border-sand-200" open>
            <summary class="flex items-center justify-between font-sans text-[13px] font-medium text-sand-900 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              {group.label}
              <svg class="w-3 h-3 transition-transform duration-300 group-open:rotate-90 text-sand-900/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6" />
              </svg>
            </summary>
            
            <div class="pb-4 flex flex-col gap-3 animate-fade-in">
              {group.options.map((opt) => (
                <label class="flex items-center gap-3 cursor-pointer group/label">
                  <div class="relative flex items-center justify-center w-4 h-4 rounded-f2-sm border-[1.5px] border-sand-300 bg-white group-hover/label:border-sand-400 f2-transition">
                    {/* Checkbox Oculto con clase 'peer' de Tailwind */}
                    <input type="checkbox" name={group.label.toLowerCase()} value={opt} class="peer absolute inset-0 opacity-0 cursor-pointer" />
                    {/* Caja visual reactiva al estado del peer */}
                    <div class="w-full h-full bg-petrol rounded-f2-sm scale-0 peer-checked:scale-100 peer-focus-visible:ring-2 peer-focus-visible:ring-watermelon peer-focus-visible:ring-offset-1 transition-transform duration-150 flex items-center justify-center">
                      <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path d="M5 13l4 4L19 7" />
                      </svg>
                    </div>
                  </div>
                  <span class="font-sans text-[13px] text-sand-900/70 group-hover/label:text-sand-900 f2-transition">{opt}</span>
                </label>
              ))}
            </div>
          </details>
        ))}

        {/* Price Range Slider */}
        <div class="py-4 border-b border-sand-200">
          <p class="flex items-center justify-between font-sans text-[13px] font-medium text-sand-900 mb-2 cursor-default">
            Price Range
            <span class="text-[12px] text-sand-900/50 font-normal">$0 — $5,000+</span>
          </p>
          <input 
            type="range" 
            class="w-full h-[3px] bg-sand-200 rounded-sm appearance-none cursor-pointer accent-petrol mt-3 focus:outline-none focus:ring-2 focus:ring-watermelon focus:ring-offset-2" 
            min="0" max="5000" step="100" value="5000" aria-label="Max price" 
          />
        </div>
      </div>
    </aside>

    {/* Product Area (slot) */}
    <div class="min-w-0">
      <slot />
    </div>

  </div>
</MainLayout>