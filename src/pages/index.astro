---
/**
 * index.astro — Homepage
 * BeautyHome · NODO Studio
 *
 * Arquitectura:
 * - Data fetching validado por Astro Content Collections (Zod).
 * - Event-Driven Architecture para el flujo del carrito.
 * - Stats computados dinámicamente desde la colección — cero ficción.
 * - Query param ?category= filtra la grilla en el servidor (SSG-compatible).
 */

import MainLayout     from "../components/templates/MainLayout.astro";
import ProductGrid    from "../components/organisms/ProductGrid.astro";
import Button         from "../components/atoms/Button.astro";
import Eyebrow        from "../components/atoms/Eyebrow.astro";
import StatCounter    from "../components/atoms/StatCounter.astro";
import TrustItem      from "../components/atoms/TrustItem.astro";
import CategoryCard   from "../components/molecules/CategoryCard.astro";
import CategoryNav    from "../components/molecules/CategoryNav.astro";
import { getCollection } from "astro:content";
import { HomeContent } from "../data/homeContent";
import HeroGallery from "../components/organisms/HeroGallery.astro";
import BrandStorySection from "../components/organisms/BrandStorySection.astro";
import NewsletterSection from "../components/organisms/NewsletterSection.astro";
import { formatCurrency } from "../utils/formatters";

// ── 1. Colección validada ─────────────────────────────────────────────────────
const productsCollection = await getCollection("products");
const allProducts = productsCollection.map((item) => ({
  ...item.data,
  id: item.id,
}));

// ── 2. Stats reales — NO hardcodeados ────────────────────────────────────────
const totalProducts  = allProducts.length;
const totalRating    = allProducts.reduce((sum, p) => sum + (p.rating ?? 0), 0);
const avgRating      = totalProducts > 0 ? (totalRating / totalProducts).toFixed(1) : "—";
const categories     = [...new Set(allProducts.map((p) => p.category))];
const totalStudios   = categories.length; // Una categoría ≈ una familia curada

// ── 3. Hero dinámico ──────────────────────────────────────────────────────────
const heroProduct       = allProducts.find((p) => p.id === "cama-nido-autor") ?? allProducts[0];
// Fix #5 — variante dinámica desde el propio producto
const heroVariantLabel  = heroProduct.variants?.[0]?.label ?? "Standard";
// Fix #7 — usa formatCurrency en lugar de Intl inline
const heroFormattedPrice = formatCurrency(heroProduct.price);

// ── 4. Filtrado por ?category= ────────────────────────────────────────────────
// Fix #4 — el query param ahora filtra de verdad en build-time (Prerendering)
const activeCategory = Astro.url.searchParams.get("category") ?? "all";
const featuredProducts =
  activeCategory === "all"
    ? allProducts.filter((p) => p.featured)
    : allProducts.filter(
        (p) =>
          p.featured ||
          p.category?.toLowerCase().includes(activeCategory.toLowerCase()),
      );

// ── 5. Category Cards — conteos reales ───────────────────────────────────────
// Fix #2 + Fix #5 (hrefs y conteos reales desde la colección)
const CATEGORY_CARDS = [
  { id: "living",    label: "Categoría", name: "Descanso",      href: "/category/living" },
  { id: "dining",    label: "Categoría", name: "Alimentación",  href: "/category/dining" },
  { id: "workspace", label: "Categoría", name: "Juego y Paseo", href: "/category/workspace" },
  { id: "bienestar", label: "Categoría", name: "Bienestar",     href: "/category/bienestar" },
].map((cat) => ({
  ...cat,
  count: allProducts.filter((p) => p.category === cat.id).length,
}));

// ── 6. Category Pills  ────────────────────────────────────────────────────────
const CATEGORY_PILLS = [
  { emoji: "✦",  label: "Todo",          value: "all" },
  { emoji: "🛏️", label: "Descanso",      value: "living" },
  { emoji: "🥩", label: "Alimentación",  value: "dining" },
  { emoji: "🎾", label: "Juego y Paseo", value: "workspace" },
  { emoji: "🧼", label: "Bienestar",     value: "bienestar" },
];
---

<MainLayout
  title="KORA — Diseño para ellos, armonía para vos."
  description="Piezas de confort para tu compañero que conviven en armonía con el diseño de interiores. Orgullo platense."
>

  {/* ─── HERO SECTION ─── */}
  <HeroGallery slides={HomeContent.heroSlides} />

  {/* ─── STATS STRIP ─── */}
  <div class="bg-white py-12 border-b border-sand-200">
    <div class="max-w-[1320px] mx-auto px-8 flex justify-center gap-12 md:gap-24">
      <StatCounter value={`${totalProducts}`}   label={HomeContent.stats.productsLabel} />
      <StatCounter value={`${totalStudios}`}    label={HomeContent.stats.studiosLabel} />
      <StatCounter value={`${avgRating}★`}      label={HomeContent.stats.ratingLabel} />
    </div>
  </div>

  {/* ─── TRUST BAND ─── */}
  {/* Fix #8 — TrustItem atom con SVG accesible en lugar de emojis sin a11y */}
  <div class="bg-sand-100 border-y border-sand-200 py-8" role="list" aria-label="Our promises">
    <div class="max-w-[1320px] mx-auto px-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {HomeContent.trust.map(item => (
        <TrustItem icon={item.icon as any} title={item.title} sub={item.sub} />
      ))}
    </div>
  </div>


  {/* ─── PRODUCT GRID ─── */}
  <section class="py-16" aria-labelledby="featured-heading">
    <div class="max-w-330 mx-auto px-8">
      <ProductGrid
        products={featuredProducts as any}
        layout="featured"
        label={HomeContent.featured.label}
        title={HomeContent.featured.title}
        subtitle={HomeContent.featured.subtitle}
        showFilters={true}
        showSort={true}
        ctaLabel={HomeContent.featured.ctaLabel}
        ctaHref="/collections"
      />
    </div>
  </section>

  {/* ─── BRAND STORY ─── */}
  <BrandStorySection 
    supplier={HomeContent.brandStory.supplier}
    isLocal={HomeContent.brandStory.isLocal}
    title={HomeContent.brandStory.title}
    description={HomeContent.brandStory.description}
    image={HomeContent.brandStory.image}
    ctaHref={HomeContent.brandStory.ctaHref}
  />

  {/* ─── CATEGORY SHOWCASE ─── */}
  <section class="py-16 md:py-24" aria-labelledby="categories-heading">
    <div class="max-w-[1320px] mx-auto px-8">
      <div class="mb-10">
        <Eyebrow text={HomeContent.categories.eyebrow} color="sand" class="mb-2" />
        <h2 class="font-display text-4xl font-light text-petrol" id="categories-heading">
          {HomeContent.categories.titleLine1}<br /><em class="italic text-sand-900/70">{HomeContent.categories.titleLine2}</em>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {CATEGORY_CARDS.map((cat, i) => (
          <CategoryCard
            id={cat.id}
            name={cat.name}
            label={cat.label}
            href={cat.href}
            count={cat.count}
            class={`${i === CATEGORY_CARDS.length - 1 ? "md:last:col-span-2 lg:last:col-span-1" : ""}`}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ─── NEWSLETTER ─── */}
  <NewsletterSection />

</MainLayout>

<script>
  // Script exclusivo para el Hero Button — usa data-hero-variant dinámico
  // Los botones de la ProductGrid ya tienen su script en ProductCard.astro
  const heroCartBtn = document.querySelector('[data-hero-add-to-cart]');

  if (heroCartBtn) {
    heroCartBtn.addEventListener('click', (e) => {
      e.preventDefault();
      const el = e.currentTarget as HTMLElement;
      const id = el.dataset.heroAddToCart;
      // Fix #5 — usa la variante del propio producto, no hardcodeada
      const variant = el.dataset.heroVariant ?? 'Standard';

      if (id) {
        window.dispatchEvent(new CustomEvent('cart:add', {
          detail: { id, variant }
        }));
      }
    });
  }
</script>