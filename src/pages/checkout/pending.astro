---
/**
 * /checkout/pending — Payment Pending
 * BeautyHome · NODO Studio
 * * Esta página se muestra cuando el usuario elige métodos de pago offline
 * (Rapipago, Pagofácil, Transferencia, etc.) o cuando la pasarela demora.
 */
import MainLayout from "../../components/templates/MainLayout.astro";

export const prerender = false;

// Capturamos el ID de pago enviado por MercadoPago a través de la URL
const paymentId = Astro.url.searchParams.get("payment_id");
---

<MainLayout title="Order Pending — BeautyHome" noIndex={true}>
    <div
        class="max-w-[800px] mx-auto px-5 md:px-8 py-20 flex flex-col items-center text-center animate-fade-in-up"
    >
        <div class="relative mb-8">
            <div
                class="w-20 h-20 rounded-full bg-gold-100 flex items-center justify-center relative z-10 border border-gold-400/20"
            >
                <svg
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="text-gold-700"
                >
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
            </div>
            <div
                class="absolute inset-0 w-20 h-20 rounded-full bg-gold-400/10 animate-ping opacity-20"
            >
            </div>
        </div>

        <p
            class="font-sans text-[11px] tracking-[0.2em] uppercase text-gold-700 font-bold mb-3"
        >
            Waiting for confirmation
        </p>

        <h1
            class="font-display text-[clamp(36px,5vw,52px)] font-light text-petrol leading-[1.1] mb-6"
        >
            Your pieces are <em>reserved</em>
        </h1>

        <p
            class="font-sans text-[16px] text-sand-900/60 leading-relaxed mb-8 max-w-[480px] text-balance"
        >
            We've received your order request. Once your payment is confirmed,
            we'll begin the artisan preparation of your items.
        </p>

        {
            paymentId && (
                <div class="mb-10 px-4 py-2 bg-sand-100 rounded-full inline-flex items-center gap-3 border border-sand-200">
                    <span class="font-sans text-[11px] uppercase tracking-wider text-sand-900/40">
                        Order Reference
                    </span>
                    <code class="font-mono text-[13px] text-petrol font-semibold">
                        {paymentId}
                    </code>
                </div>
            )
        }

        <div
            class="w-full max-w-[500px] bg-white border border-sand-200 rounded-f2-xl p-8 text-left shadow-f2-rest mb-12"
        >
            <h2
                class="font-display text-xl text-petrol mb-6 border-b border-sand-100 pb-4"
            >
                Next Steps
            </h2>

            <ul class="space-y-6">
                <li class="flex gap-4">
                    <span
                        class="w-6 h-6 rounded-full bg-sand-50 text-gold-700 flex shrink-0 items-center justify-center text-[11px] font-bold border border-gold-200"
                        >1</span
                    >
                    <div class="space-y-1">
                        <p class="text-[14px] font-medium text-sand-900">
                            Check your inbox
                        </p>
                        <p class="text-[13px] text-sand-900/50 leading-relaxed">
                            Instructions and the payment voucher have been sent
                            to your email address.
                        </p>
                    </div>
                </li>
                <li class="flex gap-4">
                    <span
                        class="w-6 h-6 rounded-full bg-sand-50 text-gold-700 flex shrink-0 items-center justify-center text-[11px] font-bold border border-gold-200"
                        >2</span
                    >
                    <div class="space-y-1">
                        <p class="text-[14px] font-medium text-sand-900">
                            Processing time
                        </p>
                        <p class="text-[13px] text-sand-900/50 leading-relaxed">
                            Once paid, it may take up to 48 business hours for
                            the artisan studios to receive the confirmation.
                        </p>
                    </div>
                </li>
            </ul>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 w-full max-w-[400px]">
            <a
                href="/collections"
                class="btn btn-primary btn-lg flex-1 no-underline"
            >
                Keep Shopping
            </a>
            <a
                href="/account"
                class="btn btn-secondary btn-lg flex-1 no-underline"
            >
                View Order Status
            </a>
        </div>

        <p class="mt-12 text-[12px] text-sand-900/30 font-sans italic">
            Questions? Contact our atelier at <span
                class="border-b border-sand-200">support@beautyhome.com</span
            >
        </p>
    </div>
</MainLayout>

<script>
    import { cartItems } from "../../store/cart.ts";

    // 1. Limpieza de estado post-intento de venta
    // Vaciamos el carrito porque la intención de compra ya fue procesada y el stock reservado.
    document.addEventListener(
        "astro:page-load",
        () => {
            cartItems.set({});
        },
        { once: true },
    );
</script>
