---
/**
 * /checkout/success — Payment Success
 * KORA · NODO Studio
 * * * Arquitectura:
 * - Renderizado en servidor (SSR) para capturar IDs de transacción.
 * - Limpieza de Stores sincronizada con el ciclo de vida de la página.
 * - Feedback personalizado recuperando datos del persistent store antes de borrarlos.
 */
import MainLayout from "../../components/templates/MainLayout.astro";
import { CheckoutContent } from "../../data/checkoutContent.ts";
import { NavContent } from "../../data/navContent.ts";

export const prerender = false;

// Capturamos los datos que envía MercadoPago en la redirección
const paymentId = Astro.url.searchParams.get("payment_id");
---

<MainLayout
  title={`${CheckoutContent.success.title} — ${NavContent.logo}`}
  description="Thank you for your purchase. Your order is now being processed."
  noIndex={true}
>
  <div
    class="max-w-[700px] mx-auto px-5 md:px-8 py-20 flex flex-col items-center text-center animate-[fadeUp_0.5s_cubic-bezier(0.33,1,0.68,1)_both]"
  >
    <div class="relative mb-10">
      <div
        class="w-24 h-24 rounded-full bg-sand-100 flex items-center justify-center relative z-10 border border-sand-200 shadow-sm"
      >
        <svg
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="var(--color-petrol)"
          stroke-width="1.5"
        >
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
      </div>

      <span class="absolute -top-2 -left-2 text-2xl animate-bounce select-none"
        >✨</span
      >
      <span
        class="absolute -bottom-2 -right-2 text-2xl animate-bounce select-none [animation-delay:0.2s]"
        >✦</span
      >
    </div>

    <p
      class="font-sans text-[11px] tracking-[0.25em] uppercase text-petrol font-bold mb-4"
    >
      {CheckoutContent.success.eyebrow}
    </p>

    <h1
      class="font-display text-[clamp(40px,6vw,60px)] font-light text-petrol leading-[1.1] mb-6"
      set:html={CheckoutContent.success.displayTitle}
    />

    <div
      class="bg-white border border-sand-200 rounded-f2-xl p-8 w-full max-w-[480px] mb-12"
    >
      <p class="font-sans text-[16px] text-sand-900/70 leading-relaxed mb-6">
        {CheckoutContent.success.messageStart}
        <br />
        <strong id="display-email" class="text-petrol font-medium"
          >tu correo</strong
        >
      </p>

      {
        paymentId && (
          <div class="pt-6 border-t border-sand-100 flex flex-col items-center">
            <span class="font-sans text-[11px] uppercase tracking-widest text-sand-900/40 mb-2">
              {CheckoutContent.success.transactionId}
            </span>
            <code class="font-mono text-[14px] text-petrol font-semibold bg-sand-50 px-3 py-1 rounded-full border border-sand-200">
              {paymentId}
            </code>
          </div>
        )
      }
    </div>

    <div class="flex flex-col sm:flex-row gap-4 w-full max-w-[440px]">
      <a href="/collections" class="f2-button-primary flex-1 no-underline text-center">
        {CheckoutContent.success.btnPrimary}
      </a>
      <a href="/account" class="f2-button-outline flex-1 no-underline text-center">
        {CheckoutContent.success.btnSecondary}
      </a>
    </div>

    <div class="mt-16 space-y-2">
      <p class="text-[12px] text-sand-900/40 font-sans italic">
        {CheckoutContent.success.note}
      </p>
      <p
        class="text-[11px] text-sand-900/40 font-sans uppercase tracking-widest"
      >
        {CheckoutContent.success.footer}
      </p>
    </div>
  </div>
</MainLayout>

<script>
  import { cartItems } from "../../store/cart.ts";
  import { customerInfo, clearCustomerInfo } from "../../store/customer.ts";
  import confetti from "canvas-confetti";

  document.addEventListener(
    "astro:page-load",
    () => {
      // 1. Recuperamos el email para el feedback visual ANTES de limpiar el store
      const savedEmail = customerInfo.get().email;
      const emailDisplay = document.getElementById("display-email");

      if (emailDisplay && savedEmail) {
        emailDisplay.textContent = savedEmail;
      }

      // 2. 🎉 Lanzamos la celebración (Colores KORA: Petrol, Rust, Gold/Sand)
      confetti({
        particleCount: 150,
        spread: 70,
        origin: { y: 0.6 },
        colors: ["#0b3948", "#E87C68", "#dcc87a"],
        disableForReducedMotion: true,
      });

      // 3. 🛡️ LIMPIEZA DE SEGURIDAD
      cartItems.set({});
      clearCustomerInfo();
    },
    { once: true },
  ); 
</script>
