---
/**
 * /checkout/failure — Payment Failed
 * BeautyHome · NODO Studio
 */
import MainLayout from "../../components/templates/MainLayout.astro";

export const prerender = false;

const reason = Astro.url.searchParams.get("status_detail") ?? "";

const REJECTION_MESSAGES: Record<string, string> = {
    cc_rejected_insufficient_amount: "Your card doesn't have enough funds.",
    cc_rejected_bad_filled_card_number:
        "The card number you entered is incorrect.",
    cc_rejected_bad_filled_date: "The expiry date you entered is incorrect.",
    cc_rejected_bad_filled_security_code:
        "The security code you entered is incorrect.",
    cc_rejected_blacklist: "This card can't be processed. Please try another.",
    cc_rejected_call_for_authorize:
        "Please contact your bank to authorize this payment.",
    cc_rejected_duplicate_payment: "This payment appears to be a duplicate.",
    cc_rejected_high_risk:
        "This payment was declined. Please try another card.",
};

const friendlyMessage =
    REJECTION_MESSAGES[reason] ??
    "The payment couldn't be processed. Please try again or use a different payment method.";
---

<MainLayout title="Payment Failed — BeautyHome" noIndex={true}>
    <div
        class="max-w-[600px] mx-auto px-5 md:px-8 py-20 flex flex-col items-center text-center"
    >
        <div
            class="w-20 h-20 rounded-full bg-watermelon/8 border-2 border-watermelon/15 flex items-center justify-center mb-8"
        >
            <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                class="text-watermelon"
            >
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="15" y1="9" x2="9" y2="15"></line>
                <line x1="9" y1="9" x2="15" y2="15"></line>
            </svg>
        </div>
        <p
            class="font-sans text-[11px] tracking-[0.18em] uppercase text-watermelon/70 mb-3"
        >
            Payment Declined
        </p>
        <h1
            class="font-display text-[clamp(32px,4vw,46px)] font-light text-petrol leading-[1.1] mb-4"
        >
            Something went wrong
        </h1>
        <p
            class="font-sans text-[15px] text-sand-900/60 leading-relaxed mb-10 max-w-[400px]"
        >
            {friendlyMessage}
        </p>
        <div class="flex flex-col sm:flex-row gap-3 w-full max-w-[360px]">
            <a
                href="/checkout"
                class="f2-button-primary flex-1 flex items-center justify-center gap-2 h-12 text-[12px] tracking-[0.07em] uppercase no-underline"
            >
                <svg
                    width="13"
                    height="13"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    ><line x1="19" y1="12" x2="5" y2="12"></line><path
                        d="M12 19l-7-7 7-7"></path></svg
                >
                Try Again
            </a>
            <a
                href="/"
                class="flex-1 h-12 flex items-center justify-center font-sans text-[12px] tracking-[0.07em] uppercase text-sand-900/60 border border-sand-200 rounded-f2-md bg-white hover:border-sand-900/30 hover:text-sand-900 f2-transition no-underline"
                >Go Home</a
            >
        </div>
    </div>
</MainLayout>
