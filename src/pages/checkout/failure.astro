---
/**
 * /checkout/failure — Payment Failed
 * KORA · NODO Studio
 * * Arquitectura:
 * - Traduce los crípticos errores de MP a lenguaje humano y premium.
 * - Intencionalmente NO borra el carrito ni los datos del store
 * para facilitar el reintento inmediato.
 */
import MainLayout from "../../components/templates/MainLayout.astro";
import { CheckoutContent, MP_REJECTION_MESSAGES } from "../../data/checkoutContent.ts";
import { NavContent } from "../../data/navContent.ts";

export const prerender = false;

// MercadoPago envía el motivo del rechazo en el query param 'status_detail'
const reason = Astro.url.searchParams.get("status_detail") ?? "";

const friendlyMessage =
    MP_REJECTION_MESSAGES[reason as keyof typeof MP_REJECTION_MESSAGES] ?? CheckoutContent.failure.fallbackMessage;
---

<MainLayout title={`${CheckoutContent.failure.title} — ${NavContent.logo}`} noIndex={true}>
    <div
        class="max-w-[600px] mx-auto px-5 md:px-8 py-20 flex flex-col items-center text-center animate-[fadeUp_0.5s_cubic-bezier(0.33,1,0.68,1)_both]"
    >
        <div class="relative mb-8">
            <div
                class="w-20 h-20 rounded-full bg-watermelon/10 flex items-center justify-center relative z-10 border border-watermelon/20"
            >
                <svg
                    width="32"
                    height="32"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    class="text-watermelon"
                >
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="15" y1="9" x2="9" y2="15"></line>
                    <line x1="9" y1="9" x2="15" y2="15"></line>
                </svg>
            </div>
            <div
                class="absolute inset-0 w-20 h-20 rounded-full bg-watermelon/5 animate-ping opacity-20"
            >
            </div>
        </div>

        <p
            class="font-sans text-[11px] tracking-[0.2em] uppercase text-watermelon font-bold mb-3"
        >
            {CheckoutContent.failure.eyebrow}
        </p>

        <h1
            class="font-display text-[clamp(36px,5vw,52px)] font-light text-petrol leading-[1.1] mb-6"
            set:html={CheckoutContent.failure.displayTitle}
        />

        <div
            class="bg-white border border-watermelon/20 rounded-f2-lg p-6 w-full max-w-[440px] mb-8"
        >
            <p
                class="font-sans text-[15px] text-sand-900/80 leading-relaxed font-medium"
            >
                {friendlyMessage}
            </p>
        </div>

        <ul
            class="text-left font-sans text-[13px] text-sand-900/60 space-y-3 mb-12 w-full max-w-[400px]"
        >
            <li class="flex items-center gap-2">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="var(--color-rust)"
                    stroke-width="2"
                    ><polyline points="20 6 9 17 4 12"></polyline></svg
                >
                {CheckoutContent.failure.listPoint1}
            </li>
            <li class="flex items-center gap-2">
                <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="var(--color-rust)"
                    stroke-width="2"
                    ><polyline points="20 6 9 17 4 12"></polyline></svg
                >
                {CheckoutContent.failure.listPoint2}
            </li>
        </ul>

        <div class="flex flex-col sm:flex-row gap-4 w-full max-w-[440px]">
            <a
                href="/checkout"
                class="f2-button-primary flex-1 group no-underline text-center justify-center flex"
            >
                <svg
                    class="transition-transform duration-200 group-hover:-translate-x-1"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <path d="M12 19l-7-7 7-7"></path>
                </svg>
                {CheckoutContent.failure.btnPrimary}
            </a>
            <a href="/" class="f2-button-outline flex-1 no-underline text-center">
                {CheckoutContent.failure.btnSecondary}
            </a>
        </div>

        <div class="mt-12 pt-8 border-t border-sand-200 w-full max-w-[440px]" set:html={CheckoutContent.failure.footer} />
    </div>
</MainLayout>

