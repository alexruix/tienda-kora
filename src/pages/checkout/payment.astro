---
/**
 * /checkout/payment — Payment Page
 * BeautyHome · NODO Studio
 *
 * Step 2: Formulario de pago con MercadoPago Bricks.
 * Recibe ?pid=preferenceId desde el query param.
 * El PUBLIC_KEY viaja como prop al island (nunca el ACCESS_TOKEN).
 */
import MainLayout from "../../components/templates/MainLayout.astro";
import PaymentBricks from "../../components/organisms/PaymentBricks.jsx";

export const prerender = false;

const preferenceId = Astro.url.searchParams.get("pid");
const publicKey = import.meta.env.PUBLIC_MP_PUBLIC_KEY;

// Si no hay preferenceId, redirigir al checkout
if (!preferenceId) {
    return Astro.redirect("/checkout");
}
---

<MainLayout
    title="Payment — BeautyHome"
    description="Complete your payment."
    noIndex={true}
>
    <!-- Breadcrumb -->
    <nav
        class="bg-sand-50 border-b border-sand-200 py-4"
        aria-label="Breadcrumb"
    >
        <div class="max-w-[1100px] mx-auto px-5 md:px-8">
            <ol
                class="flex items-center gap-2 text-[13px] text-sand-900/50 flex-wrap"
            >
                <li>
                    <a href="/" class="hover:text-sand-900 f2-transition"
                        >Home</a>
                </li>
                <li aria-hidden="true">›</li>
                <li>
                    <a
                        href="/checkout"
                        class="hover:text-sand-900 f2-transition">Checkout</a>
                </li>
                <li aria-hidden="true">›</li>
                <li aria-current="page" class="text-sand-900 font-medium">
                    Payment
                </li>
            </ol>
        </div>
    </nav>

    <!-- Step indicator -->
    <div class="border-b border-sand-200 bg-white">
        <div class="max-w-[1100px] mx-auto px-5 md:px-8 py-4">
            <div
                class="flex items-center gap-3 text-[12px] font-sans tracking-[0.06em] uppercase"
            >
                <span class="flex items-center gap-1.5 text-sand-900/40">
                    <span
                        class="w-5 h-5 rounded-full bg-sand-100 text-sand-900/30 flex items-center justify-center text-[10px]"
                    >
                        <svg
                            width="10"
                            height="10"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                        >
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </span>
                    Details
                </span>
                <span class="text-sand-200">——</span>
                <span class="flex items-center gap-1.5 text-petrol font-medium">
                    <span
                        class="w-5 h-5 rounded-full bg-petrol text-white flex items-center justify-center text-[10px] font-bold"
                        >2</span
                    >
                    Payment
                </span>
            </div>
        </div>
    </div>

    <!-- Payment area -->
    <div class="max-w-[680px] mx-auto px-5 md:px-8 py-10 lg:py-14">
        <!-- Header -->
        <div class="mb-8">
            <p
                class="font-sans text-[11px] tracking-[0.18em] uppercase text-sand-900/40 mb-2"
            >
                Step 2 of 2
            </p>
            <h1
                class="font-display text-[clamp(32px,4vw,44px)] font-light text-petrol leading-[1.1] mb-2"
            >
                Payment
            </h1>
            <p class="font-sans text-[14px] text-sand-900/50">
                Your data is protected. We don't store card information.
            </p>
        </div>

        <!-- MP Bricks container -->
        <div
            class="bg-white rounded-f2-lg border border-sand-200 overflow-hidden p-6 shadow-f2-rest"
        >
            <PaymentBricks
                publicKey={publicKey}
                preferenceId={preferenceId}
                client:only="react"
            />
        </div>

        <!-- Back link -->
        <div class="mt-6 text-center">
            <a
                href="/checkout"
                class="inline-flex items-center gap-2 font-sans text-[12px] tracking-[0.06em] uppercase text-sand-900/40 hover:text-sand-900 f2-transition no-underline group"
            >
                <svg
                    class="transition-transform duration-150 group-hover:-translate-x-1"
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <path d="M12 19l-7-7 7-7"></path>
                </svg>
                Edit details
            </a>
        </div>
    </div>
</MainLayout>
