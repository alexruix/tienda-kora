---
/**
 * /checkout/payment — Payment Page (Step 2)
 * BeautyHome · NODO Studio
 */
import MainLayout from "../../components/templates/MainLayout.astro";
import PaymentBricks from "../../components/organisms/PaymentBricks.jsx";

export const prerender = false;

const preferenceId = Astro.url.searchParams.get("pid");
const publicKey = import.meta.env.PUBLIC_MP_PUBLIC_KEY;
const amount = Astro.url.searchParams.get("amt");

// 1. Guard de Seguridad
if (!preferenceId || !amount) {
    return Astro.redirect("/checkout");
}

// 2. Formateador de moneda nativo para mostrar el total
const formattedTotal = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "ARS",
    minimumFractionDigits: 0,
}).format(Number(amount));
---

<MainLayout
    title="Secure Payment — BeautyHome"
    description="Complete your order using our secure payment gateway."
    noIndex={true}
>
    <script src="https://sdk.mercadopago.com/js/v2" is:inline></script>

    <nav
        class="bg-sand-50 border-b border-sand-200 py-4"
        aria-label="Breadcrumb"
    >
        <div class="checkout-container">
            <ol
                class="flex items-center gap-2 text-[13px] text-sand-900/50 flex-wrap"
            >
                <li>
                    <a href="/" class="hover:text-sand-900 f2-transition"
                        >Home</a>
                </li>
                <li aria-hidden="true">›</li>
                <li>
                    <a
                        href="/checkout"
                        class="hover:text-sand-900 f2-transition">Checkout</a>
                </li>
                <li aria-hidden="true">›</li>
                <li aria-current="page" class="text-sand-900 font-medium">
                    Payment
                </li>
            </ol>
        </div>
    </nav>

    <div class="border-b border-sand-200 bg-white">
        <div class="checkout-container py-4">
            <div class="flex items-center gap-4">
                <div class="step-item text-sand-900/40">
                    <span
                        class="step-bullet bg-green-50 text-green-600 border border-green-100"
                    >
                        <svg
                            width="10"
                            height="10"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="3"
                        >
                            <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                    </span>
                    <span>Details</span>
                </div>

                <span class="step-connector" aria-hidden="true">————</span>

                <div class="step-item step-item--active">
                    <span class="step-bullet">2</span>
                    <span>Payment</span>
                </div>
            </div>
        </div>
    </div>

    <div
        class="max-w-[680px] mx-auto px-5 md:px-8 py-10 lg:py-14 animate-fade-in-up"
    >
        <header
            class="mb-10 text-center lg:text-left flex flex-col lg:flex-row lg:items-end justify-between gap-4 border-b border-sand-200 pb-6"
        >
            <div>
                <p
                    class="font-sans text-[11px] tracking-[0.18em] uppercase text-sand-900/40 mb-2"
                >
                    Final Step
                </p>
                <h1
                    class="font-display text-[clamp(32px,4vw,44px)] font-light text-petrol leading-[1.1] mb-3"
                >
                    Secure <em>Payment</em>
                </h1>
                <div
                    class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-50 rounded-full border border-green-100"
                >
                    <svg
                        width="12"
                        height="12"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#059669"
                        stroke-width="2.5"
                    >
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                        ></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <span
                        class="text-[11px] font-sans font-medium text-green-700 uppercase tracking-wider"
                        >PCI-DSS Encrypted</span
                    >
                </div>
            </div>

            <div
                class="text-center lg:text-right bg-sand-50/50 p-4 rounded-f2-lg border border-sand-100"
            >
                <p
                    class="font-sans text-[12px] uppercase tracking-widest text-sand-900/40 mb-1"
                >
                    Total to pay
                </p>
                <p class="font-display text-2xl text-petrol">
                    {formattedTotal}
                </p>
            </div>
        </header>

        <div
            class="bg-white rounded-f2-lg border border-sand-200 overflow-hidden shadow-f2-rest p-1 sm:p-6 min-h-[400px] relative"
        >
            <PaymentBricks
                publicKey={publicKey}
                amount={Number(amount)}
                preferenceId={preferenceId}
                client:only="react"
            />

            <div
                id="payment-skeleton"
                class="absolute inset-0 bg-white p-6 z-10 space-y-6 transition-opacity duration-500"
            >
                <div class="h-10 bg-sand-50 rounded-f2-md w-full animate-pulse">
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div class="h-10 bg-sand-50 rounded-f2-md animate-pulse">
                    </div>
                    <div class="h-10 bg-sand-50 rounded-f2-md animate-pulse">
                    </div>
                </div>
                <div class="h-20 bg-sand-50 rounded-f2-md w-full animate-pulse">
                </div>
                <div
                    class="h-12 bg-sand-200 rounded-f2-lg w-full animate-pulse mt-10"
                >
                </div>
            </div>
        </div>

        <div class="mt-8 flex flex-col items-center gap-4">
            <p
                class="text-[13px] text-sand-900/40 font-sans text-center max-w-[400px]"
            >
                By clicking "Pay", you agree to our terms of service. Your
                payment is processed safely through MercadoPago's secure
                infrastructure.
            </p>

            <a
                href="/checkout"
                class="btn btn-ghost text-[11px] tracking-widest group no-underline"
            >
                <svg
                    class="transition-transform duration-200 group-hover:-translate-x-1"
                    width="12"
                    height="12"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <path d="M12 19l-7-7 7-7"></path>
                </svg>
                Back to Details
            </a>
        </div>
    </div>
</MainLayout>

<script is:inline>
    // Transición suave: fade out opacity, luego display none
    window.addEventListener("mercadopago:ready", () => {
        const skeleton = document.getElementById("payment-skeleton");
        if (skeleton) {
            skeleton.style.opacity = "0";
            setTimeout(() => {
                skeleton.style.display = "none";
            }, 500); // 500ms coincide con la clase duration-500 de Tailwind
        }
    });
</script>
