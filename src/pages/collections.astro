---
/**
 * /collections — All Collections Page
 * BeautyHome · NODO Studio
 *
 * Arquitectura:
 * - Agrupa todos los productos por categoría principal usando Content Collections.
 * - Cada categoría se muestra como una sección independiente con su ProductGrid.
 * - SSG: generado en build time, sin SSR necesario.
 */

import MainLayout     from "../components/templates/MainLayout.astro";
import ProductGrid    from "../components/organisms/ProductGrid.astro";
import SectionHeader  from "../components/molecules/SectionHeader.astro";
import { getCollection } from "astro:content";

const productsData = await getCollection("products");
const allProducts = productsData.map((p) => ({ ...p.data, id: p.id }));

// Agrupar por categoría principal (antes del " · ")
const categoriesMap = new Map<string, { label: string; products: typeof allProducts }>();

for (const product of allProducts) {
  const mainCat = product.category?.split(" · ")[0] ?? "Other";
  const key = mainCat.toLowerCase();
  if (!categoriesMap.has(key)) {
    categoriesMap.set(key, { label: mainCat, products: [] });
  }
  categoriesMap.get(key)!.products.push(product);
}

const categories = Array.from(categoriesMap.entries())
  .map(([id, data]) => ({ id, ...data }))
  .sort((a, b) => a.label.localeCompare(b.label));

const CATEGORY_DESCRIPTIONS: Record<string, string> = {
  living: "Sofas, lighting, tables, and objects for a living room with quiet, confident character.",
  dining: "Tables and seating designed for the ritual of shared meals and conversation.",
  workspace: "Objects chosen for focus, clarity, and the feeling of a mind at ease.",
};

const totalCount = allProducts.length;
---

<MainLayout
  title="All Collections — BeautyHome"
  description="Browse our complete catalog of curated artisan home objects. Organized by space — Living, Dining, Workspace, and beyond."
>
  {/* ─── PAGE HEADER ─── */}
  <header class="bg-petrol text-white relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/5 rounded-full translate-x-1/3 -translate-y-1/3" />
      <div class="absolute bottom-0 left-0 w-[300px] h-[300px] bg-watermelon/10 rounded-full -translate-x-1/2 translate-y-1/2" />
    </div>

    <div class="ds-container py-20 lg:py-28 relative z-10 animate-fade-in-up">
      <p class="font-sans text-[11px] tracking-[0.3em] uppercase text-watermelon mb-4 flex items-center gap-3 before:content-[''] before:w-8 before:h-px before:bg-watermelon before:shrink-0">
        Curated Catalog
      </p>
      <h1 class="font-display text-[clamp(48px,6vw,80px)] font-light leading-[1.05] mb-6 text-white">
        All <em class="italic text-sand-200/80">Collections</em>
      </h1>
      <p class="font-sans text-base text-white/60 leading-[1.8] max-w-[480px] mb-10">
        {totalCount}+ carefully chosen pieces from {categories.length} collections —
        each one selected for its quiet confidence and lasting character.
      </p>

      {/* Category Navigation Pills */}
      <nav class="flex gap-2 flex-wrap" aria-label="Jump to collection">
        {categories.map((cat) => (
          <a
            href={`#collection-${cat.id}`}
            class="inline-flex items-center gap-2 font-sans text-[12px] tracking-[0.08em] uppercase px-4 py-2 rounded-f2-md bg-white/10 border border-white/20 text-white/70 hover:bg-white/20 hover:text-white transition-all duration-200 no-underline"
          >
            {cat.label}
            <span class="text-white/40 text-[10px]">{cat.products.length}</span>
          </a>
        ))}
      </nav>
    </div>
  </header>

  {/* ─── COLLECTION SECTIONS ─── */}
  {categories.map((cat) => (
    <section
      id={`collection-${cat.id}`}
      class="py-16 lg:py-24 border-b border-sand-200 last:border-none scroll-mt-[88px]"
      aria-labelledby={`heading-${cat.id}`}
    >
      <div class="ds-container">
        {/* Section Header */}
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10 pb-8 border-b border-sand-200">
            <SectionHeader
              eyebrow={`Collection · ${cat.products.length} pieces`}
              title={cat.label}
              subtitle={CATEGORY_DESCRIPTIONS[cat.id]}
              id={`heading-${cat.id}`}
            />
          <a
            href={`/category/${cat.id}`}
            class="btn btn-secondary btn-md shrink-0 no-underline"
            aria-label={`View all ${cat.label} pieces`}
          >
            View all {cat.label} →
          </a>
        </div>

        {/* Product Grid */}
        <ProductGrid
          products={cat.products as any}
          layout="default"
        />
      </div>
    </section>
  ))}

  {/* ─── BOTTOM CTA ─── */}
  <div class="bg-sand-100 border-t border-sand-200 py-20 text-center">
    <div class="max-w-[600px] mx-auto px-8 animate-fade-in-up">
      <SectionHeader
        eyebrow="Looking for something specific?"
        eyebrowColor="sand"
        title="Our concierge is here"
        subtitle="Can't find what you're looking for? Our team of interior specialists can source any piece and advise on curation for your space."
        align="center"
      />
      <div class="mt-8">
        <a href="mailto:concierge@beautyhome.com" class="btn btn-primary btn-lg no-underline">Contact Concierge</a>
      </div>
    </div>
  </div>
</MainLayout>
