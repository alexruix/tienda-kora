---
/**
 * /account — Account Page
 * KORA · NODO Studio
 *
 * Arquitectura (Preparada para Supabase):
 * - Página SSR (prerender: false)
 * - Muestra condicionalmente la vista Guest (AuthModule) o Dashboard (Logueado)
 * - Actualmente utiliza `localStorage` como stub, listo para conectar Supabase Auth.
 */

export const prerender = false;

import MainLayout from "../components/templates/MainLayout.astro";
import { AuthModule } from "../components/organisms/AuthModule.jsx";
import { AccountContent } from "../data/accountContent";

const { guest, dashboard } = AccountContent;
---

<MainLayout
  title="Mi Cuenta — KORA"
  description={guest.description}
  noIndex={true}
>
  {/* ─── GUEST VIEW (Auth) ─── */}
  <div id="account-guest-view" class="hidden">
    {/* Header Section */}
    <div class="bg-petrol text-white py-16 px-5">
      <div class="max-w-[480px] mx-auto text-center">
        <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 mb-6">
          <span class="text-[11px] font-sans tracking-widest uppercase font-semibold">{guest.eyebrow}</span>
        </div>
        <h1 class="font-display text-[clamp(32px,5vw,48px)] font-light leading-tight mb-4">
          {guest.title}
        </h1>
        <p class="font-sans text-[15px] text-white/70 leading-relaxed">
          {guest.description}
        </p>
      </div>
    </div>

    {/* Benefits strip */}
    <div class="bg-sand-50 border-b border-sand-200">
      <div class="max-w-[700px] mx-auto px-5 py-8 grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4', title: 'Historial de Pedidos', desc: 'Seguí tus compras en tiempo real' },
          { icon: 'M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z', title: 'Favoritos Guardados', desc: 'Tus piezas preferidas, siempre disponibles' },
          { icon: 'M13 10V3L4 14h7v7l9-11h-7z', title: 'Checkout Más Rápido', desc: 'Tus datos se completan solos' },
        ].map(b => (
          <div class="flex items-start gap-3 bg-white rounded-f2-lg border border-sand-200 px-4 py-4">
            <div class="w-9 h-9 rounded-full bg-petrol/5 flex items-center justify-center text-petrol shrink-0">
              <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                <path d={b.icon}/>
              </svg>
            </div>
            <div>
              <p class="font-sans text-[13px] font-semibold text-petrol mb-0.5">{b.title}</p>
              <p class="font-sans text-[12px] text-sand-900/50">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* Auth form */}
    <div class="py-12 px-5">
      <AuthModule client:load onAuthSuccess={() => window.location.reload()} />

      <div class="max-w-[440px] mx-auto text-center mt-10 bg-sand-50 rounded-f2-lg border border-sand-200 p-5">
        <p class="font-sans text-[13px] text-sand-900/60 leading-relaxed" set:html={guest.wishlistNote} />
      </div>
    </div>
  </div>


  {/* ─── LOGGED IN VIEW (Dashboard) ─── */}
  <div id="account-dashboard-view" class="hidden">
    {/* Header */}
    <header class="bg-sand-100 border-b border-sand-200 pt-24 pb-10">
      <div class="max-w-[1100px] mx-auto px-5 md:px-8">
        <div class="flex items-center gap-5">
          <div
            id="account-avatar"
            class="w-16 h-16 rounded-full bg-petrol flex items-center justify-center text-white font-display text-2xl font-light shrink-0"
            aria-hidden="true"
          >
            ✦
          </div>
          <div>
            <p class="font-sans text-[11px] tracking-widest uppercase text-sand-900/40 mb-1">
              {dashboard.welcome}
            </p>
            <h1
              id="account-name-header"
              class="font-display text-[clamp(28px,3vw,40px)] font-light text-petrol leading-none"
            >
              {guest.title}
            </h1>
          </div>
        </div>
      </div>
    </header>

    <div class="max-w-[1100px] mx-auto px-5 md:px-8 py-12 lg:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-[240px_1fr] gap-10 lg:gap-16 items-start">
        {/* Sidebar Nav */}
        <nav class="lg:sticky lg:top-24" aria-label="Secciones de la cuenta">
          <ul class="space-y-1" role="list">
            {dashboard.nav.map((item) => (
              <li role="listitem">
                {item.href ? (
                  <a
                    href={item.href}
                    class={`flex items-center gap-3 px-4 py-3 rounded-f2-md font-sans text-[14px] no-underline transition-all duration-150 text-sand-900/70 hover:bg-sand-100 hover:text-sand-900`}
                  >
                    <span class="text-base" aria-hidden="true">{item.icon}</span>
                    {item.label}
                  </a>
                ) : (
                  <button
                    class={`w-full flex items-center gap-3 px-4 py-3 rounded-f2-md font-sans text-[14px] text-left border-none cursor-pointer transition-all duration-150 ${
                      item.id === 'orders'
                        ? "bg-petrol text-white font-medium"
                        : "bg-transparent text-sand-900/70 hover:bg-sand-100 hover:text-sand-900"
                    }`}
                    aria-current={item.id === 'orders' ? "page" : undefined}
                    data-section={item.id}
                  >
                    <span class="text-base" aria-hidden="true">{item.icon}</span>
                    {item.label}
                  </button>
                )}
              </li>
            ))}
          </ul>

          <div class="mt-8 pt-8 border-t border-sand-200">
            <button
              id="logout-btn"
              class="w-full flex items-center gap-3 px-4 py-3 rounded-f2-md font-sans text-[14px] text-left border-none cursor-pointer text-sand-900/50 hover:bg-sand-100 hover:text-sand-900 bg-transparent transition-all duration-150"
            >
              <span class="text-base" aria-hidden="true">🚪</span>
              {dashboard.logout}
            </button>
          </div>
        </nav>

        {/* Main Panel */}
        <main>
          {/* ORDERS SECTION */}
          <section aria-labelledby="orders-heading">
            <div class="flex items-center justify-between mb-8">
              <h2 id="orders-heading" class="font-display text-[28px] font-light text-petrol">
                {dashboard.orders.title}
              </h2>
              <span id="order-count" class="font-sans text-[12px] text-sand-900/40 tracking-[0.06em]"></span>
            </div>

            <div
              id="orders-guest"
              class="bg-white rounded-f2-xl border border-sand-200 p-10 text-center animate-[fadeInUp_0.6s_ease-out_both]"
            >
              <div class="w-16 h-16 rounded-full bg-sand-100 flex items-center justify-center mx-auto mb-6">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-sand-900/30">
                  <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z" />
                  <line x1="3" y1="6" x2="21" y2="6" />
                  <path d="M16 10a4 4 0 0 1-8 0" />
                </svg>
              </div>
              <h3 class="font-display text-2xl font-light text-petrol mb-2">{dashboard.orders.empty.title}</h3>
              <p class="font-sans text-[14px] text-sand-900/50 mb-8 max-w-sm mx-auto leading-relaxed">
                {dashboard.orders.empty.description}
              </p>
              <a href="/collections" class="btn btn-primary btn-md no-underline">
                {dashboard.orders.empty.cta}
              </a>
            </div>
          </section>

          {/* PROFILE QUICK CARD */}
          <section class="mt-12" aria-labelledby="profile-quick-heading">
            <h2 id="profile-quick-heading" class="font-display text-[22px] font-light text-petrol mb-6">
              {dashboard.profile.title}
            </h2>
            <div class="bg-white rounded-f2-xl border border-sand-200 overflow-hidden">
              <div class="px-6 py-4 border-b border-sand-100 flex items-center justify-between">
                <p class="font-sans text-[12px] tracking-widest uppercase text-sand-900/40">
                  {dashboard.profile.status}
                </p>
                <span id="profile-status" class="font-sans text-[11px] text-sand-900/30">{dashboard.profile.loading}</span>
              </div>

              <dl class="divide-y divide-sand-100" id="profile-fields">
                {[
                  { label: dashboard.profile.fields.name,  id: "f-name"  },
                  { label: dashboard.profile.fields.email, id: "f-email" },
                  { label: dashboard.profile.fields.phone, id: "f-phone" },
                  { label: dashboard.profile.fields.dni,   id: "f-dni"   },
                ].map((field) => (
                  <div class="flex items-center gap-4 px-6 py-4">
                    <dt class="font-sans text-[12px] tracking-[0.06em] uppercase text-sand-900/40 w-20 shrink-0">
                      {field.label}
                    </dt>
                    <dd id={field.id} class="font-sans text-[14px] text-sand-900/70 flex-1">
                      —
                    </dd>
                  </div>
                ))}
              </dl>
            </div>
          </section>

          {/* LOYALTY CARD */}
          <section class="mt-12" aria-labelledby="loyalty-heading">
            <div class="bg-petrol rounded-f2-xl p-8 text-white relative overflow-hidden">
              <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
                <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full translate-x-1/2 -translate-y-1/2" />
              </div>
              <div class="relative z-10">
                <p class="font-sans text-[11px] tracking-widest uppercase text-watermelon mb-3">
                  {dashboard.loyalty.eyebrow}
                </p>
                <h2 id="loyalty-heading" class="font-display text-[28px] font-light text-white mb-3">
                  {dashboard.loyalty.title}
                </h2>
                <p class="font-sans text-[13px] text-white/60 leading-relaxed mb-6 max-w-sm">
                  {dashboard.loyalty.description}
                </p>
                <div class="flex flex-wrap gap-4">
                  <a href="mailto:hola@kora.com" class="btn btn-sm no-underline bg-white/10! text-white/80! border-white/20! border hover:bg-white/20! hover:text-white!">
                    {dashboard.loyalty.ctaSupport}
                  </a>
                  <a href="/wishlist" class="btn btn-sm no-underline bg-transparent! text-white/60! hover:text-white!">
                    {dashboard.loyalty.ctaWishlist}
                  </a>
                </div>
              </div>
            </div>
          </section>

        </main>
      </div>
    </div>
  </div>
</MainLayout>

<script>
  import { customerInfo } from "../store/customer.ts";

  document.addEventListener("astro:page-load", () => {
    const customer = customerInfo.get();
    
    // Auth Toggle Mockup
    // Cuando instalemos Supabase, reemplazaremos esto con un chequeo de sesión real (auth.getSession())
    const isLoggedIn = !!customer.email; // Temporal: Asumimos logueado si hay un email guardado en el store local
    
    const guestView = document.getElementById("account-guest-view");
    const dashboardView = document.getElementById("account-dashboard-view");

    if (isLoggedIn) {
      guestView?.classList.add("hidden");
      dashboardView?.classList.remove("hidden");
      dashboardView?.classList.add("block");
    } else {
      dashboardView?.classList.add("hidden");
      guestView?.classList.remove("hidden");
      guestView?.classList.add("block");
    }

    // Llenar datos de Dashboard
    if (isLoggedIn) {
      const avatar = document.getElementById("account-avatar");
      if (avatar && customer.name) {
        const initials = [customer.name[0], customer.surname?.[0]]
          .filter(Boolean)
          .join("")
          .toUpperCase();
        avatar.textContent = initials || "✦";
      }

      const accountName = document.getElementById("account-name-header");
      if (accountName && customer.name) {
        accountName.textContent = `${customer.name} ${customer.surname || ""}`.trim();
      }

      const fields: Record<string, string> = {
        "f-name":  [customer.name, customer.surname].filter(Boolean).join(" ") || "—",
        "f-email": customer.email || "—",
        "f-phone": customer.phone || "—",
        "f-dni":   customer.dni   || "—",
      };

      for (const [id, value] of Object.entries(fields)) {
        const el = document.getElementById(id);
        if (el) el.textContent = value;
      }

      const statusEl = document.getElementById("profile-status");
      if (statusEl) {
        statusEl.textContent = "Sincronizado";
      }
    }

    // Mock Logout para testing rápido
    document.getElementById("logout-btn")?.addEventListener("click", () => {
      customerInfo.set({ name: "", surname: "", email: "", phone: "", dni: "" });
      window.location.reload();
    });
  });
</script>
