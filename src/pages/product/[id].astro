---
/**
 * product/[id].astro — Dynamic Product Detail Page
 * BeautyHome · NODO Studio
 * * Arquitectura Segura:
 * - El ID del archivo es la única fuente de verdad para el enrutamiento y el carrito.
 * - Los detalles se renderizan dinámicamente desde Zod.
 * - Compatible con Astro View Transitions (ClientRouter).
 */

import MainLayout from "../../components/templates/MainLayout.astro";
import ProductDetails from "../../components/organisms/ProductDetails.astro";
import RecommendGrid from "../../components/organisms/RecommendGrid.astro";
import { getCollection } from "astro:content";
import { formatCurrency } from "../../utils/formatters.ts";

// 1. Rutas Estáticas y Sincronización de IDs
export async function getStaticPaths() {
    const products = await getCollection("products");

    // Mapeamos asegurando que cada producto tenga su ID real
    const allProductsMapped = products.map((p) => ({ ...p.data, id: p.id }));

    return products.map((product) => ({
        params: { id: product.id }, // Usamos el ID del archivo
        props: {
            product: { ...product.data, id: product.id },
            allProducts: allProductsMapped,
        },
    }));
}

const { product, allProducts } = Astro.props;

// 2. Filtramos productos relacionados (misma categoría, distinto ID)
const related = allProducts
    .filter((p) => p.category === product.category && p.id !== product.id)
    .slice(0, 4);

const formattedPrice = formatCurrency(product.price);

// 4. Truncado inteligente para SEO
const seoDescription =
    product.description && product.description.length > 160
        ? product.description.slice(0, 160).split(" ").slice(0, -1).join(" ") +
          "..."
        : product.description;
---

<MainLayout title={`${product.name} — KORA`} description={seoDescription}>
    {/* ─── Breadcrumb ─── */}
    <nav class="bg-sand-50 border-b border-sand-200 py-4" aria-label="Breadcrumb">
        <div class="max-w-[1320px] mx-auto px-5 md:px-8">
            <ol class="flex items-center gap-2 text-[13px] text-sand-900/50 flex-wrap">
                <li><a href="/" class="hover:text-sand-900 f2-transition">Home</a></li>
                <li aria-hidden="true">›</li>
                <li>
                    <a href={`/category/${product.category.toLowerCase()}`} class="hover:text-sand-900 f2-transition">
                        {product.category}
                    </a>
                </li>
                <li aria-hidden="true">›</li>
                <li aria-current="page" class="text-sand-900 font-medium">{product.name}</li>
            </ol>
        </div>
    </nav>

    {/* ─── Core Product Details ─── */}
    <ProductDetails product={product} />

    {/* ─── Related Products ─── */}
    {related.length > 0 && (
        <section class="py-16 bg-sand-100 border-t border-sand-200">
            <RecommendGrid 
                products={related as any} 
                title="Completá el espacio con <em>piezas de autor</em>"
                subtitle="Recomendados para vos"
            />
        </section>
    )}
</MainLayout>
