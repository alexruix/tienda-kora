---
/**
 * /sale — Sale Page
 * BeautyHome · NODO Studio
 *
 * Arquitectura:
 * - Filtra productos con badge "sale" O con originalPrice definido.
 * - Calcula el ahorro real para cada producto.
 * - SSG: generado en build time.
 */

import MainLayout from "../components/templates/MainLayout.astro";
import ProductGrid from "../components/organisms/ProductGrid.astro";
import { getCollection } from "astro:content";
import { FREE_SHIPPING_THRESHOLD, SHIPPING_COST } from "../utils/shipping";

const freeShippingLabel = new Intl.NumberFormat("es-AR", {
  style: "currency",
  currency: "ARS",
  minimumFractionDigits: 0,
}).format(FREE_SHIPPING_THRESHOLD);

const productsData = await getCollection("products");
const allProducts = productsData.map((p) => ({ ...p.data, id: p.id }));

// Productos en venta: badge "sale" o tienen precio original mayor al actual
const saleProducts = allProducts.filter(
  (p) =>
    p.badges?.includes("sale") ||
    (p.originalPrice && p.originalPrice > p.price)
);

// Calcular estadísticas del sale para el header
const totalSavings = saleProducts.reduce((sum, p) => {
  if (p.originalPrice && p.originalPrice > p.price) {
    return sum + (p.originalPrice - p.price);
  }
  return sum;
}, 0);

const maxDiscountPct = saleProducts.reduce((max, p) => {
  if (p.originalPrice && p.originalPrice > p.price) {
    const pct = Math.round(((p.originalPrice - p.price) / p.originalPrice) * 100);
    return Math.max(max, pct);
  }
  return max;
}, 0);

const formattedSavings = new Intl.NumberFormat("en-US", {
  style: "currency",
  currency: "ARS",
  minimumFractionDigits: 0,
}).format(totalSavings);
---

<MainLayout
  title={`Sale — Up to ${maxDiscountPct}% Off · BeautyHome`}
  description={`Shop our curated sale selection — up to ${maxDiscountPct}% off artisan-crafted home objects. Limited time, limited stock.`}
>
  {/* ─── SALE HERO ─── */}
  <header class="bg-watermelon relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute -top-20 -right-20 w-[400px] h-[400px] bg-white/5 rounded-full" />
      <div class="absolute bottom-0 left-1/4 w-[200px] h-[200px] bg-white/5 rounded-full translate-y-1/2" />
    </div>

    <div class="max-w-[1320px] mx-auto px-5 md:px-8 py-16 lg:py-24 relative z-10 animate-fade-in-up text-white">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8">
        <div>
          <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 mb-6">
            <span class="text-[11px] font-sans tracking-[0.16em] uppercase font-semibold">
              ✦ Limited Time Offer
            </span>
          </div>
          <h1 class="font-display text-[clamp(52px,7vw,96px)] font-light leading-[0.95] mb-4">
            Up to<br />
            <em class="italic text-white/80">{maxDiscountPct}% Off</em>
          </h1>
          <p class="font-sans text-[15px] text-white/70 leading-relaxed max-w-md">
            Rare savings on our most celebrated artisan pieces — crafted to last decades,
            now at exceptional value.
          </p>
        </div>

        {/* Stats */}
        <div class="flex gap-8 lg:gap-12 shrink-0 pb-2">
          <div class="text-center">
            <span class="block font-display text-[40px] font-light text-white leading-none mb-1">
              {saleProducts.length}
            </span>
            <span class="block font-sans text-[11px] tracking-[0.12em] uppercase text-white/50">
              Pieces on sale
            </span>
          </div>
          <div class="w-px bg-white/20 self-stretch" aria-hidden="true" />
          <div class="text-center">
            <span class="block font-display text-[40px] font-light text-white leading-none mb-1">
              {maxDiscountPct}%
            </span>
            <span class="block font-sans text-[11px] tracking-[0.12em] uppercase text-white/50">
              Max discount
            </span>
          </div>
        </div>
      </div>
    </div>

    {/* Bottom wave separator */}
    <div class="h-12 bg-sand-50 rounded-t-[40px] -mb-1" aria-hidden="true" />
  </header>

  {/* ─── TRUST STRIP ─── */}
  <div class="bg-sand-50 border-b border-sand-200 py-5">
    <div class="max-w-[1320px] mx-auto px-5 md:px-8">
      <ul class="flex flex-wrap gap-x-8 gap-y-3 justify-center text-[12px] font-sans text-sand-900/50 tracking-[0.04em]" role="list">
        {[
          "🔄  60-day returns on all sale items",
          `🚚  Free shipping over ${freeShippingLabel}`,
          "✦  Same artisan quality, lower price",
          "⚡  Limited stock — no restocking",
        ].map((item) => (
          <li role="listitem">{item}</li>
        ))}
      </ul>
    </div>
  </div>

  {/* ─── PRODUCT GRID ─── */}
  <section class="max-w-[1320px] mx-auto px-5 md:px-8 py-16 lg:py-20" aria-labelledby="sale-heading">
    {saleProducts.length > 0 ? (
      <>
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
          <div>
            <p class="font-sans text-[11px] tracking-[0.22em] uppercase text-watermelon mb-1">
              Sale Selection
            </p>
            <h2 id="sale-heading" class="font-display text-3xl font-light text-petrol">
              {saleProducts.length} pieces at reduced prices
            </h2>
          </div>
          <p class="font-sans text-[13px] text-sand-900/40">
            Ends when stock runs out
          </p>
        </div>

        <ProductGrid
          products={saleProducts as any}
          layout="default"
          showSort={true}
        />
      </>
    ) : (
      <div class="flex flex-col items-center justify-center py-32 text-center animate-fade-in-up">
        <div class="w-16 h-16 rounded-full bg-sand-100 flex items-center justify-center mb-6">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-sand-900/30">
            <circle cx="12" cy="12" r="10" />
            <path d="M12 8v4m0 4h.01" />
          </svg>
        </div>
        <h2 class="font-display text-3xl font-light text-petrol mb-3">No sale items right now</h2>
        <p class="font-sans text-[14px] text-sand-900/50 max-w-sm mb-8">
          Our next sale event is coming soon. Browse our full collection in the meantime.
        </p>
        <a href="/collections" class="btn btn-primary btn-md no-underline">Browse All Collections</a>
      </div>
    )}
  </section>

  {/* ─── BOTTOM CTA ─── */}
  {saleProducts.length > 0 && (
    <div class="bg-petrol text-white py-16 text-center">
      <div class="max-w-[500px] mx-auto px-8 animate-fade-in-up">
        <p class="font-sans text-[11px] tracking-widest uppercase text-white/40 mb-4">
          Curated for you
        </p>
        <h2 class="font-display text-[clamp(28px,3vw,40px)] font-light mb-6">
          Not finding what you need?
        </h2>
        <a href="/collections" class="btn btn-secondary btn-lg no-underline !bg-white/10 !text-white/80 !border-white/25 hover:!bg-white/20 hover:!text-white">
          Explore Full Collection →
        </a>
      </div>
    </div>
  )}
</MainLayout>
