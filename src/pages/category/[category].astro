---
/**
 * category/[category].astro — Dynamic Category Page
 * BeautyHome · NODO Studio
 */

import CategoryLayout from '../../components/templates/CategoryLayout.astro';
import ProductGrid from '../../components/organisms/ProductGrid.astro';
import { getCollection } from 'astro:content';
import { CategoryContent } from '../../data/categoryContent';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  
  const uniqueCategories = [
    ...new Set(
      allProducts
        .filter(p => p.data.category)
        .map((p) => p.data.category.split(' ·')[0].toLowerCase())
    ),
  ];

  return uniqueCategories.map((category) => {
    const filteredProducts = allProducts
      .filter((p) => p.data.category.toLowerCase().startsWith(category))
      .map((p) => ({
        ...p.data,
        id: p.id
      }));

    return {
      params: { category },
      props: { 
        products: filteredProducts 
      },
    };
  });
}

const { category } = Astro.params;
const { products } = Astro.props;

const content = CategoryContent.categories[category as keyof typeof CategoryContent.categories] || CategoryContent.categories.living;
---

<CategoryLayout
  category={category as any}
  title={`${content.name} — KORA`}
  description={content.description}
  productCount={products.length}
>
  <ProductGrid
    products={products as any} 
    layout="default"
  />
</CategoryLayout>