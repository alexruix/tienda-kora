---
/**
 * category/[category].astro — Dynamic Category Page
 * BeautyHome · NODO Studio
 */

import CategoryLayout from '../../components/templates/CategoryLayout.astro';
import ProductGrid from '../../components/organisms/ProductGrid.astro';
import { getCollection } from 'astro:content';
import { CategoryContent } from '../../data/categoryContent';

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  
  const uniqueCategories = [
    ...new Set(
      allProducts
        .filter(p => p.data.category)
        .map((p) => p.data.category.split(' ·')[0].toLowerCase())
    ),
  ];

  return uniqueCategories.map((category) => {
    const filteredProducts = allProducts
      .filter((p) => p.data.category.toLowerCase().startsWith(category))
      .map((p) => ({
        ...p.data,
        id: p.id
      }));

    return {
      params: { category },
      props: { 
        products: filteredProducts 
      },
    };
  });
}

const { category } = Astro.params;
const { products } = Astro.props;

const content = CategoryContent.categories[category as keyof typeof CategoryContent.categories] || CategoryContent.categories.living;

// Extraer subcategorías específicas para los filtros laterales si estamos en una sola categoría
const subCategories = [...new Set(products.map(p => (p as any).subcategory || p.category?.split(' · ')[1]))].filter(Boolean) as string[];

const customFilters = subCategories.length > 0 ? [
  { label: category === 'ropa' ? 'Tipo de Prenda' : 'Subcategoría', options: subCategories },
  { label: CategoryContent.filters.material, options: CategoryContent.filters.options.materials },
  { label: CategoryContent.filters.style,    options: CategoryContent.filters.options.styles },
] : undefined;
---

<CategoryLayout
  category={category as any}
  title={`${content.name} — KORA`}
  description={content.description}
  productCount={products.length}
  filters={customFilters}
>
  <ProductGrid
    products={products as any} 
    layout="default"
    showFilters={true}
    showSort={true}
  />
</CategoryLayout>